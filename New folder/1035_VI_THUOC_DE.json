  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T1035",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "1035"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Ngọt (Cam)"
        ],
        "tinh": "Nhiệt",
        "quy_kinh": [
          "K_TY",
          "K_VI",
          "K_CAN"
        ],
        "cong_nang": "trợ dương, bổ tinh huyết",
        "kieng_ky_dac_biet": "Không đề cập"
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Ở nước ta hiện nay có ba giống dê chính: đê Việt Nam, dê Ấn Độ và dê Mông Cổ. Gốc giống dê nuôi vốn là giống dê núi Capra prisca, sau giống dê này được thuần hóa, lai tạp với nhiều giống dê khác như dê núi Ấn Độ Capra aegagrus. Dê Việt Nam chưa rõ nguồn gốc ở đâu, có hình vóc nhỏ, chỉ cao chừng $50cm$, mình dẹp, chân nhỏ, lông nhiều màu sắc, tai đứng, sừng hơi cong nhọn đưa về phía sau, dài từ $8$ đến $15cm$, thỉnh thoảng có con sừng nhú hơi cong về phía trước. Dê đực mình ngắn, vạm vỡ, to hơn dê cái, đầu cổ và sống lưng có lông dài cứng, chùm râu cằm rậm, sừng dài, khi già có thể xoắn lại. Dê cái trong đều đặn, hiền hậu. Dê Ấn Độ do người Pháp và Ấn Độ mang vào nước ta vào đầu thế kỷ 20, đã thích nghi với khí hậu nước ta. Dê Ấn Độ có thân dài và cao $80-$ $90cm$, trông mảnh khảnh, mắt thường lồi lên, tai to và rủ xuống, sừng ngắn hay không có sừng. Long màu sẫm đen hoặc xám nhạt, vú to. Dê Mông Cổ mới nhập vào nước ta khoảng vài chục năm gần đây. Mình vừa phải, to hơn dê ta nhưng nhỏ hơn dễ Ấn Độ. Tại thẳng và mảnh, sừng dài, thẳng, hơi chếch về phía sau. Lông có màu trắng đen. Đặc biệt lông có hai thứ: lông thô dài cứng thò ra bên ngoài, lông tơ ngắn mềm ở bên trong có thể dùng làm len (Hình 759). [CT_VT_VN_T1036]: Hình 760. Sơn dương Chú thích: Không nên nhầm con dê núi Capra prisca và con sơn dương có tên khoa học Capri cornis sumatrensis cũng gọi là con dê núi hay dê rừng thường ở núi đá vôi. Cả hai con này đều được dùng làm thuốc như dê nhà nhưng hiếm và quý hơn (Hình 760).",
        "thanh_phan_hoa_hoc": [
          "[CT_VT_VN_T1036]: Theo Viện vệ sinh dịch tễ Hà Nội (1972) trong $100g$ thịt dê có $17,5\\%$ protit, $40\\%$ lipit. Nhưng hiện nay đối với các nước người ta chú ý so sánh thành phần hóa học của sữa dê với một số sữa khác: Loại sữa Cặn khô Chất béo Protit Anbumin globulin Lactoza Muối khoáng Độ axit \\% \\% \\% \\% \\% \\% Sữa dê $13,1$ $4,1$ $5,5$ $1,7$ $4,6$ $0,85$ Sữa bò $12,8$ $3,7$ $3,5$ $0,6$ $4,6$ $0,80$ 16-18 Sữa trâu $18,2$ $7,1$ $4,05$ $5,0$ 18-22 Sữa cừu $17,1$ $6,7$ $5,8$ $5,7$ $0,82$ 20-25"
        ]
      }
    }
  ],
