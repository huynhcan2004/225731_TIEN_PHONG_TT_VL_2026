      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Nguyên tố có sẵn trong thiên nhiên. Dạng bột hoặc cục màu vàng tươi, mùi đặc biệt, không tan trong nước/rượu. Cháy với lửa xanh tạo mùi khét khó thở.",
        "thanh_phan_hoa_hoc": [
          "Thành phần chủ yếu là $sunfua$ nguyên chất. Có thể lẫn tạp chất asen, sắt, đất."
        ],
        "cach_dung_bao_che": "Chế từ khoáng vật lưu hoàng thiên nhiên. Dùng trong thuốc súng và kỹ nghệ hóa học."
      }
    }
  ],
