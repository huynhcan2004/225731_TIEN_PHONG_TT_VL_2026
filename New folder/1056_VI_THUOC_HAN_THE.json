      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Hàn the hay bàng sa (borax) là tinh thể màu trắng, hay bột màu trắng vị hơi nồng, không có mùi. Để ngoài trời mất nước dần và thành bột màu trắng; nếu đun nóng thì chảy ở $107C$, sau đó phồng lên mất dần nước để cho chất hàn the nung.",
        "thanh_phan_hoa_hoc": [],
        "lieu_dung_tong_quat": "null",
        "ghi_chu_bo_sung": "null",
        "cach_dung_bao_che": "Hàn the có thể dùng sống; tán nhỏ hoặc cho vào nồi hay chảo sao cho sủi bọt, lấy ra để nguội."
      }
    }
