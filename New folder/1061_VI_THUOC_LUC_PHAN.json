      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Lục phàn có tinh thể trong mờ, hay trong màu xanh nhạt, để lâu ra không khí sẽ thường bị oxy hóa cho màu vàng nhạt, ròn dễ vỡ vụn, vị sáp.",
        "thanh_phan_hoa_hoc": [
          "Trong lục phần thiên nhiên chủ yếu có sắt sunfat ($FeSO, 7H,O$). Tạp chất gồm magiê ($Mg$), mangan ($Mn$), canxi ($Ca$).",
          "Lục phàn tự chế lấy không có các tạp chất."
        ]
      }
    }
  ],
