      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Còn gọi là hồng thăng, hồng phấn, hồng thăng đơn, hoàng thăng, thăng đơn, tam tiêu đơn. Là lớp phấn đỏ dày chừng $3mm$, có những đám óng ánh tinh thể.",
        "thanh_phan_hoa_hoc": [
          "Thành phần chủ yếu là Thủy ngân oxyt ($HgO$)."
        ],
        "cach_dung_bao_che": "Chế từ Thủy ngân ($40g$), Diêm tiêu ($80g$), Minh phàn ($80g$). Trộn đều cho vào bát, úp bát khác lên buộc chặt, trát kín bằng xi măng. Đun lò than củi nhẹ trong 8 tiếng. Khi nguội, nạo lấy lớp phấn đỏ phủ trên mặt trong của bát trên gọi là hồng phấn hay hồng thăng."
      }
    }
