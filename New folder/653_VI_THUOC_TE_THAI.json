  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T653",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "653"
      },
      "dac_tinh_yhct": {
        "quy_kinh": [
          "K_CAN",
          "K_TY",
          "K_PHE",
          "K_THAN",
          "K_VI",
          "K_DAI_TRANG"
        ],
        "cong_nang": "lợi gan, hoà trung, lợi ngũ tạng, rễ dùng chữa đau mắt, làm sáng mắt, ích dạ dày, rễ và lá đốt thanh than chữa xích bạch lỵ; hạt minh mục (làm sáng mắt) chữa đau mắt, thong manh, bổ ngũ tạng, chữa lỵ lâu ngày."
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây mọc hằng năm hay $2$ năm. Thân gầy nhỏ, màu xanh lục nhạt có lông mịn, phân nhánh hoặc không phân nhánh. Cao từ $20-40cm$. Lá phía gốc mọc sát mặt đất thành hoa thị, cuống ngắn hoặc không cuống; phiến lá xẻ thành nhiều răng cưa thô to, trên phiến lá có lông nhỏ. Lá phía trên không có cuống, ôm lấy thân cây, mép có răng cưa hoặc nguyên hay hơi cắt sâu. Hoa mọc thành chùm ngắn ở đầu cành hay kẽ lá. Hoa nhỏ màu trắng. Đầu xuân nở hoa, $4$ cánh, $4$ lá đài xếp thành hình chữ thập. Nhị $4$. Bầu thượng, $2$ ngăn. Quả hình tim ngược dẹt giống cái túi của người chăn cừu bên châu Âu, do đó có tên Bursa là túi, pasoris có nghĩa là người chăn cứu ( Hình $496$, Hm $12,2$).",
        "thanh_phan_hoa_hoc": [
          "chất béo",
          "tinh dầu",
          "axit bursic",
          "$diosmin$",
          "$hysopin$",
          "$colin$",
          "$axetylcolin$",
          "men emunsin",
          "vitamin A",
          "vitamin B",
          "C",
          "K",
          "flavonozit",
          "$axit fumaric$",
          "$inozit$",
          "$ntin$",
          "$hesperidin$",
          "muối kaki"
        ],
        "lieu_dung_tong_quat": "Không rõ",
        "ghi_chu_bo_sung": "Độ ẩm không quá $13\\%$, tro toàn bộ không quá $10\\%$, tro không tan trong HCl không quá $2\\%$, tạp chất hữu cơ lẫn vào không quá $2\\%$, thân còn cả rễ không quá $3\\%$.",
        "cach_dung_bao_che": "Tề thái (Herba Capsellae) hoặc (Herba Bursae-pastoris) là toàn cây tề thái phơi hay sấy khô."
      }
    }
  ],
