        ]
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Thanh cao là một loại cỏ mọc hằng năm hay hai năm, cao chừng $0,3-1,5m$, rất nhiều cành ngay từ giữa cây. Toàn thân có mùi thơm. Lá mọc so le, hai lần xẻ lông chim, phiến lá chét rất nhỏ, mép nguyên hoặc mỗi dìa có 1-3 chỗ rách nhỏ. Cuống lá ngắn và hẹp. Cụm hoa hình đầu, đường kính $6mm$, trông như một quả con. Xung quanh là hoa cái ở giữa là hoa lưỡng tính (Hình 498).",
        "thanh_phan_hoa_hoc": [
          "Trong cây thanh cao có tinh dầu, chất đắng và một ancaloit gọi là $abrotanin$."
        ]
      }
    }
  ],
