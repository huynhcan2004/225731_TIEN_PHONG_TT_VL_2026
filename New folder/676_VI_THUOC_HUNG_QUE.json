  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T676",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "676"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây thuộc thảo, sống hằng năm, thân nhẵn hay có lông, thường phân cành ngay từ dưới gốc, cao $50$-$60cm$. Lá mọc đối có cuống, phiến lá hình thuôn dài, có thứ màu xanh lục, có thứ màu tím đen nhạt. Hoa nhỏ màu trắng hay hơi tía, mọc thành chùm đơn hay phân nhánh với những hoa mọc thành vòng 5 đến 6 hoa một. Quả chứa hạt đen bóng, khi ngâm vào nước có chất nhầy màu trắng bao quanh ( Hình 509). Để làm thuốc, người ta chỉ hái lá và ngọn có hoa (Herba Ocini) phơi hay sấy khô. Để cất tinh dầu người ta hái toàn cây, cất tươi hay để hơi héo mới cất.",
        "thanh_phan_hoa_hoc": [
          "metylchavicola",
          "estragola",
          "metylchavicola",
          "linalola",
          "xineola",
          "xinamat metyl",
          "eugenola",
          "sesquitecpen"
        ],
        "lieu_dung_tong_quat": "Mỗi ngày uống từ $10$ đến $25g$ dưới dạng thuốc sắc hay thuốc pha.",
        "ghi_chu_bo_sung": "Hạt có thể dùng đắp lên mắt đau đỏ.",
        "cach_dung_bao_che": "Cho từ 6 đến $12g$ hạt vào nước thường hay nước đường. Đợi cho chất nhầy nở ra rồi uống."
      }
    }
  ],
