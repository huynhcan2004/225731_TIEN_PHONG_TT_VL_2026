  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T736",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "736"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Bách hợp là một loại cỏ nhỏ cao độ $60-90cm$, mọc hoang ở rừng và sống lâu năm, có dò. Lá mọc so le hình mác, nhẵn, dài $2-15cm$, rộng $0,5-3,5cm$. Hoa đầu cành gồm $2-6$ hoa lớn, hình loa kèn dài $14-16cm$, miệng có $6$ cánh màu trắng hay hơi hồng, cuống dài $3-4cm$. Quả nang dài $5-6cm$, mở theo $3$ van. Hạt rất nhiều, xếp thành chồng, hình trái xoan, đường kính làm hay hơn (Hình 556, Hm 28,3). dò của cây này do nhiều lá kết lại như vẩy cá.",
        "thanh_phan_hoa_hoc": [
          "Trong bách hợp có tinh bột ($30\\%$) chất proti ($4\\%$) chất béo ($0,1\\%$) và một ít vitamin C.",
          "Có tác giả tìm thấy trong bách hợp chất $colchixein$ CGON.1/2H₂O."
        ],
        "lieu_dung_tong_quat": "Không tìm thấy",
        "ghi_chu_bo_sung": "Không tìm thấy",
        "cach_dung_bao_che": "Không tìm thấy"
      }
    }
  ],
