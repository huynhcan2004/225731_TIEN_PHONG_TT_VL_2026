  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T741",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "741"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Cay (Tân)",
