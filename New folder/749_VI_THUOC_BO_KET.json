  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T749",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "749"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Cay (Tân)",
          "Mặn (Hàm)"
        ],
        "tinh": "Ôn"
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Bồ kết là một cây to, cao $5$-$10m$, có thể tới $20m$. Thân có gai rất chắc, dài tới $10$-$15cm$. Lá kép lông chim $1$-$2$ lần, dài $15$-$20cm$. Hoa nhỏ màu trắng lục nhạt, mọc thành bông ở kẽ lá hay đầu cành. Quả giáp dài $10$-$12cm$, rộng $15$-$20mm$, dày chừng $10mm$, hơi cong hình chữ S, chứa $10$-$12$ hạt hình trứng dẹt, bóng. Mùa hoa: tháng $5$-$7$, mùa quả: tháng $8$-$10$.",
        "thanh_phan_hoa_hoc": [],
        "lieu_dung_tong_quat": "Không có thông tin",
        "ghi_chu_bo_sung": "Không có thông tin",
        "cach_dung_bao_che": "Người ta dùng quả bồ kết phơi hay sấy khô. Khi dùng có khi dùng sống, có khi đốt thành than. Có khi dùng gai bồ kết (tạo giác thích). Hạt bồ kết cũng được dùng. Tại nhiều địa phương, nhân dân còn dùng lá bồ kết để nấu nước gội đầu thay bồ kết quả. Muốn lấy quả bồ kết, người ta hái quả vào mùa thu đông, hái về phơi hay sấy khô. Khi dùng có thể dùng sống hay đốt thành than. Khi dùng người ta thường bỏ hạt đi. Gai bồ kết thường hái vào mùa xuân, thái nhỏ, phơi khô."
      }
    }
  ],
