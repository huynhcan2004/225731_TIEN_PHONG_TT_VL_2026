  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T763",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "763"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cóc mẳn là một loại cỏ nhỏ mềm, mọc bò lan trên mặt đất ẩm, phân rất nhiều cành, ở ngọn có lông mịn trắng, nhưng toàn thân trông nhẫn bóng, lá đơn mọc so le, hơi hình $3$ cạnh, đầu tù, phía cuống hẹp lại, mép có $2$ răng cưa, có khi $1$ hay $3$, dài $10$-$18mm$, rộng $6$-$10mm$, gần chính hơi nổi ở mặt dưới lá, gân phụ không rõ, không có cuống. Cụm hoa hình đầu mọc ở nách lá, hoa cái gồm nhiều lớp, cánh hoa hình ống màu trắng, trên có răng cưa, hoa lưỡng tĩnh ít hơn, tràng hoa hình chuông có $4$ răng hình trứng, rộng, màu hơi tím. Quả bế $4$ cạnh, trên cạnh có lông mịn nhỏ. Mùa hoa: các tháng $2$-$5$, mùa quả: các tháng $4$-$7$.",
        "thanh_phan_hoa_hoc": [
          "Theo Muller (Zeitz. Ast. Apot. Verein, 11-1-1878) trong cây có tinh dầu và một chất màu nâu nhạt hay vàng nhạt có vị đắng, ít tan trong nước lạnh, tan nhiều trong nước nóng, rất tan trong cồn. Muller gọi chất này là axit myriogynic.",
          "Theo Dược học tạp chí (Nhật, 1970, 90, 846) trong toàn cây cóc mẳn có $taraxasterol$, $taraxasteril axetat$ và $Arnidiol$."
        ]
      }
    }
  ],
