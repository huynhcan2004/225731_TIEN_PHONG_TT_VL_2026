  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T765",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "765"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây nhỏ xanh tốt quanh năm, lá mọc so le, hình trứng, mép có răng cưa nhỏ, gai ngắn mọc ở phía dưới lá. Vào đầu mùa hạ ra hoa màu trắng, quả chín vào mùa đông, vỏ ngoài màu vàng nâu, trên một số những múi chạy dài dọc quả phía dưới tách ra trông như ngón tay cho nên có tên phật thủ (tay phật, thủ là tay) (Hình 575).",
        "thanh_phan_hoa_hoc": [
          "Trong phật thủ có tinh dầu và một chất flavonoit gọi là $hesperidin$, vỏ quả chứa tinh dầu. Trong quả chứa $limettin$, $xitropten$, ngoài ra còn $diosmin$"
        ],
        "ghi_chu_bo_sung": "Rất dễ mốc."
      }
    }
  ],
