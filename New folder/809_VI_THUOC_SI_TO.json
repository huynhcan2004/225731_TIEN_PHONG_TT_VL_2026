      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây thảo sống lâu năm, cao $25-30cm$. Rễ mập, lá hình tim, hoa nhỏ màu trắng, quả bế dẹt. Cây nữ lang cao $1-1.5m$, thân nhẵn, lá kép lông chim, hoa nhỏ màu trắng, quả bế dẹt.",
        "thanh_phan_hoa_hoc": [],
        "lieu_dung_tong_quat": "Không có thông tin",
        "ghi_chu_bo_sung": "Mùi tinh dầu của sì to rất giống mùi của cây Valeriana officinalis ở châu Âu.",
