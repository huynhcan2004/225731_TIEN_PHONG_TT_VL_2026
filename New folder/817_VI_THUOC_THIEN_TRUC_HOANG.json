  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T817",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "817"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Ngọt (Cam)"
        ],
        "tinh": "Hàn",
        "quy_kinh": [
          "K_TAM"
        ],
        "cong_nang": "thanh nhiệt trừ đờm, định tâm, an thần, đuổi phong nhiệt"
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Thiên trúc hoàng là cặn đọng ở đốt một số cây nứa mọc ở nước ta. Những cây nứa này bị một loại bệnh làm cho chất nước trong cây ngưng đọng lại. Kích thước thiên trúc hoàng to nhỏ không nhất định: to có thể đạt tới $1-1,5cm$, nhỏ chỉ đo được $1-2mm$. Chất nhẹ, dễ vỡ vụn, nếm thì thấy dính vào lưỡi, không có mùi vị gì đặc biệt.",
        "thanh_phan_hoa_hoc": [
          "Thành phần của thiên trúc hoàng chủ yếu gồm có kali hydroxyt ($1,1\\%$), silic ($90,5\\%$), $Al_2O_3$($0,9\\%$), $Fe_2O_3$ ($0,9\\%$). Ngoài ra còn có ít canxi cacbonat."
        ],
        "cach_dung_bao_che": "Thường khi đốt nương làm rẫy, người ta thu thập thiên trúc hoàng ở những đốt cây nứa bị đốt cháy. Lấy ra phơi khô là được. Nhưng nếu đốt quá nóng, màu sắc chuyển màu xanh xám hay đen xám là kém, nếu lẫn đất cát phẩm chất còn kém hơn. Những cục trắng được coi là loại tốt."
      }
    }
  ],
