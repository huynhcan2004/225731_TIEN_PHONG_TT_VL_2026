  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T865",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "865"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "nữa cho nhẵn bóng và phơi thật khô. Nhúng nhanh vào nước lấy ra dùng giấy ráp đánh cho bóng.",
        "thanh_phan_hoa_hoc": [
          "Ngoài tinh bột ra trong hoài sơn của Trung Quốc và Nhật Bản các nhà nghiên cứu Nhật Bản đã lấy ra chất $muxin$ là một loại protit nhớt, $allantoin$, $axit amin$, $acginin$ và $cholin$. Ngoài ra còn có $mantaza$ là mem tiêu hóa mantoza. Về mặt thực phẩm, trong củ mài có chừng $63,25\\%$ chất bột, $0,45\\%$ chất béo, $6,75\\%$ chất protit. Gần đây người ta có tìm thấy trong một số giống Dioscorea chất $saponin$ có nhân sterol. Tóm lại ngoài giá trị dinh dưỡng, hoạt chất của hoài sơn chưa rõ ràng."
        ],
        "lieu_dung_tong_quat": "Ngày dùng $12-20g$ dưới dạng thuốc sắc hay thuốc bột.",
        "ghi_chu_bo_sung": "Hoài sơn là một vị thuốc bổ rất quý, được dùng trong cả đông và tây y.",
        "cach_dung_bao_che": "Chưa rõ"
      }
    }
  ],
