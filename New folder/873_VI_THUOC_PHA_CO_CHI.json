  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T873",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "873"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Cay (Tân)",
          "Đắng (Khổ)"
        ],
        "tinh": "Ôn",
        "quy_kinh": [
          "K_TY",
          "K_THAN",
          "K_TAM_BAO"
        ]
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây nhỏ mọc hằng năm, cao 0,3-1m. Trên thân có lông trắng, lá mọc so le, hình trứng đầu nhọn, đáy lá tròn, mép có răng cưa dài 6-9cm, rộng 5-7cm, cuống lá dài 2-4cm, có lá kèm. Hoa mọc thành chùm dài 6-10cm ở kẽ lá, cành hoa màu vàng nâu nhạt. Quả hình trứng màu đen dài $5mm$, rộng $3mm$. Hạt hình thận hay hình trứng dẹt dài $5mm$, rộng $3mm$ có màu nâu đen hay đen. Trên mặt hạt có vân hình những hạt nhỏ giữa hơi lõm, mùi thơm, vị cay (Hình 655).",
        "thanh_phan_hoa_hoc": [
          "Trong hạt phá cố chỉ có chừng $20\\%$ chất dầu, một ít tinh dầu trong đó có `$psoralen$`, `$isopsoralen$` (angelixin), ancaloit, glucozit và $9,2\\%$ chất nhựa."
        ]
      }
    }
  ],
