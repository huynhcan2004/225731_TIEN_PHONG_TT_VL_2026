  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T875",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "875"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Cay (Tân)",
          "Ngọt (Cam)"
        ],
        "tinh": "Đại nhiệt",
        "quy_kinh": [
          "K_CAN",
          "K_THAN"
        ],
        "cong_nang": "Bổ mệnh môn tướng hỏa, trị cố lãnh trầm hàn, dùng chữa chân tay co quắp, lưng gối tê mỏi, bụng quặn đau, kinh nguyệt bế, tiểu tiện bất lợi, trên nóng dưới lạnh, ung thư."
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Quế Thanh Hóa là một cây cao từ 12-20cm. Cành mọc trong năm có 4 cạnh, dẹt, nhẵn. Lá hơi hình trứng hai đầu hẹp lại, hơi nhọn, có 3 gân rất rõ chạy từ cuống đến đầu lá, mặt dưới phủ những vẩy nhỏ. Phiến lá dài 12-15cm, rộng 5cm. Cuống dài chừng 15mm. Hoa màu trắng mọc thành chùy ở kẽ lá hay đầu cành. Quả hạch hình trứng dài chừng 1cm, lúc đầu xanh lục, khi chín ngả màu nâu tím, mặt quả bóng, về phía cuống còn sót để hoa có lông.",
        "thanh_phan_hoa_hoc": [
          "[CT_VT_VN_T877]: Ngoài những chất như tinh bột, chất nhầy, $tanin$, chất màu, đường, trong quế Việt nam có tới 1-5\\% tinh dầu (các loài quế khác thường chỉ có 1-2\\%).",
          "Trong tinh dầu quế Việt Nam có chứa khoảng 95\\% andehyt xinnamic α=-0°8 (theo Roure Bertrand). Tinh dầu quế của ta tan trong cùng một thể tích cồn 70."
        ]
      }
    }
  ],
