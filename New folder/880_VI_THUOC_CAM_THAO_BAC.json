{
  "entity": {
    "entity_type": "VI_THUOC",
    "id": "VI_THUOC_CAM_THAO_BAC",
    "ten_raw": "Cam thảo bắc",
    "ten_khoa_hoc": "Clycyrrhiza uralensis Fish và Glycyrrhiza glabra L. (G. glandulifera Waldst et Kit)",
    "ho_thuc_vat": "Cánh bướm Fabaceae (Papilionaceae)",
    "variants": [
      "bắc cam thảo",
      "cam thảo",
      "sinh cam thảo",
      "quốc lão"
    ],
    "properties": {
      "bo_phan_dung": "rễ",
      "thu_hai": "Vào mùa hạ và mùa thu",
      "che_bien_tho": "chưa có thông tin",
      "lieu_dung_chung": "chưa có thông tin",
      "muc_do_doc": "Không độc",
      "trieu_chung_ngo_doc": "chưa có thông tin",
      "phan_bo": "Trước đây không có ở nước ta. Từ năm 1958, chúng tôi đã trồng thử một số bằng những hạt giống của loài Glycyrrhiza uralensis do Liên Xô cũ cung cấp. Cây mọc khỏe vào xuân hạ và thu. Đến mùa đông thì lại đi hoặc kém phát triển. Sang năm sau cây lại mọc tốt. Lượng hoạt chất trong rễ mỗi năm mỗi tăng. Tuy nhiên sau 3 năm cây vẫn chưa ra hoa. Có tài liệu nói cây trồng thường không có hoa.\nTại Liên Xô cũ, Trung Quốc và nhiều nước khác cây cam thảo mọc hoang và trở thành một thứ cỏ khó diệt trừ, chỉ một mẩu thân rễ có thể trở thành một bụi cam thảo và cứ như vậy lan ra rộng mãi. Những khu vực cam thảo mọc hoang là những nơi có đất khô, đất có canxi, đất cát đất cát vàng."
    },
    "display_name": "Cam thảo bắc"
  },
