    {
      "from": "VI_THUOC_DONG_TRUNG_HA_THAO",
      "to": "DL_UC_CHE",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Tiêm mạch máu hoặc dưới da thuốc đông trùng hạ thảo vào thỏ hoặc chuột nhắt trắng thì thấy hiện tượng ức chế, liều lớn tăng hô hấp và mạch đập nhanh hơn rồi con vật quằn quại mà chết. | Tác dụng ức chế rõ rệt đối với mẩu ruột và tử cung cô lập.",
        "ghi_chu": "Thí nghiệm trên thỏ và chuột nhắt trắng."
      },
      "source": {
        "source_id": "CT_VT_VN_T899"
      }
    },
    {
      "from": "VI_THUOC_DONG_TRUNG_HA_THAO",
      "to": "DL_KHANG_KHUAN",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Có tác dụng ức chế đối với một số vi trùng."
      },
      "source": {
        "source_id": "CT_VT_VN_T899"
      }
    },
    {
      "from": "VI_THUOC_DONG_TRUNG_HA_THAO",
      "to": "DL_UC_CHE_TIM",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Nước sắc 1/10 đông trùng hạ thảo có tác dụng ức chế đối với tim cô lập và tại chỗ của ếch, cũng như đối với tim cô lập của thỏ. Tim ức chế rồi chết.",
        "ghi_chu": "Thí nghiệm trên tim ếch và thỏ."
      },
      "source": {
        "source_id": "CT_VT_VN_T899"
      }
    },
    {
      "from": "VI_THUOC_DONG_TRUNG_HA_THAO",
      "to": "DL_AN_THAN",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Với liều nhẹ, con vật có trạng thái trấn tĩnh với những trình độ khác nhau, có con vật buồn ngủ và tình trạng này kéo dài hàng vài giờ."
      },
      "source": {
        "source_id": "CT_VT_VN_T899"
      }
    },
    {
      "from": "VI_THUOC_DONG_TRUNG_HA_THAO",
      "to": "DL_HA_HUYET_AP",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Nếu tiêm tĩnh mạch với liều $0,1-0,5$ $ml$ hoặc $1$ $ml/kg$ thể trọng đều thấy huyết áp hạ xuống rõ rệt, $10$ phút sau huyết áp trở lại bình thường.",
        "ghi_chu": "Thí nghiệm trên chó gây mê."
      },
      "source": {
        "source_id": "CT_VT_VN_T899"
      }
    },
    {
      "from": "VI_THUOC_DONG_TRUNG_HA_THAO",
      "to": "DL_GIAN_KHI_QUAN",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Thí nghiệm trên phổi và khí quản của chuột bạch, thấy thuốc đông trùng hạ thảo làm dãn khí quản nếu phối hợp với hoạt chất của thượng thận thì tác dụng của hoạt chất thượng thận lại tăng lên rõ rệt.",
        "ghi_chu": "Thí nghiệm trên chuột bạch."
      },
      "source": {
        "source_id": "CT_VT_VN_T899"
      }
    },
    {
      "from": "VI_THUOC_DONG_TRUNG_HA_THAO",
      "to": "DL_DOC_TINH",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Với liều $5$ $g/kg$ chuột bạch, chuột không có hiện tượng ngộ độc nào. Với liều $10-20$ $g/kg$ thể trọng một phần chuột thí nghiệm bị chết, với liều $30-50$ $g/kg$ thể trọng toàn số chuột thí nghiệm bị chết.",
        "ghi_chu": "Thí nghiệm trên chuột bạch."
      },
      "source": {
        "source_id": "CT_VT_VN_T899"
      }
    },
    {
      "from": "VI_THUOC_DONG_TRUNG_HA_THAO",
      "to": "DL_DOC_TINH_THAN_KINH",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Sau khi tiêm thuốc $2$ phút rưỡi, chuột không nhanh nhẹn, sau $4$ phút hô hấp chậm và dài, thường từ $180$ lần/phút giảm xuống $46$ lần/phút; sau $6$ phút rưỡi chân trước bị tê liệt có vẻ như muốn nhảy nhót, sau đó có hiện tượng co quắp, hô hấp bị ngưng trệ.",
        "ghi_chu": "Triệu chứng ngộ độc ở chuột."
      },
      "source": {
        "source_id": "CT_VT_VN_T899"
      }
    },
