      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Sâm cau có tác dụng kiểu oestrogen: gây động dục ở chuột cái đã cắt buồng trứng.",
        "ghi_chu": "Thí nghiệm trên chuột cái đã cắt buồng trứng."
      },
      "source": {
        "source_id": "CT_VT_VN_T927"
      }
