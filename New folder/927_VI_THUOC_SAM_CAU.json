      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Tác dụng tăng lực: làm tăng thể trọng của chuột, tăng trương lực cơ.",
        "ghi_chu": "Thí nghiệm trên chuột."
      },
      "source": {
        "source_id": "CT_VT_VN_T927"
      }
    },
    {
      "from": "VI_THUOC_SAM_CAU",
