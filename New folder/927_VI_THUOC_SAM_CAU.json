    {
      "from": "VI_THUOC_SAM_CAU",
      "to": "DL_TANG_CUONG_SINH_DUC",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Sâm cau có tác dụng tăng cường sinh dục: làm tăng trọng lượng của tinh hoàn, tăng hoạt động của tuyến sinh dục và tăng cường khả năng giao phối. Tác dụng này mạnh hơn cả nhục thung dung, dâm dương hoắc, ba kích.",
        "ghi_chu": "so sánh với các vị thuốc khác"
      },
      "source": {
        "source_id": "CT_VT_VN_T927"
      }
    },
    {
      "from": "VI_THUOC_SAM_CAU",
