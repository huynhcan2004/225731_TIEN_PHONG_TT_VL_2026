    {
      "from": "VI_THUOC_A_GIAOMINH_GIAO",
      "to": "DL_CHUYEN_HOA_CANXI",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Cải thiện sự hấp thụ canxi của động vật. Sự hấp thụ canxi được tăng là do glyxin trong a giao.",
        "ghi_chu": "Thí nghiệm trên chó."
      },
      "source": {
        "source_id": "CT_VT_VN_T962"
      }
    },
    {
      "from": "VI_THUOC_A_GIAOMINH_GIAO",
      "to": "DL_DONG_MAU",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Tiêm dung dịch $5\\%$ a giao diệt trùng thì khả năng đông máu tăng."
      },
      "source": {
        "source_id": "CT_VT_VN_T962"
      }
    },
    {
      "from": "VI_THUOC_A_GIAOMINH_GIAO",
      "to": "DL_TAO_MAU",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "A giao làm tăng nhanh lượng hồng cầu và các sắc tố của máu.",
        "ghi_chu": "Thí nghiệm trên chó bị gây thiếu máu."
      },
      "source": {
        "source_id": "CT_VT_VN_T962"
      }
    },
    {
      "from": "VI_THUOC_A_GIAOMINH_GIAO",
      "to": "DL_CHONG_LOAN_DUONG_CO",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Sau khi cho chuột bạch bị gây loạn dưỡng cơ dần dần ăn a giao thì sau hơn $100$ ngày, đa số con vật hết các triệu chứng tê liệt so với các con vật khỏe mạnh không khác nhau.",
        "ghi_chu": "Thí nghiệm trên chuột bạch."
      },
      "source": {
        "source_id": "CT_VT_VN_T962"
      }
    },
    {
      "from": "VI_THUOC_A_GIAOMINH_GIAO",
      "to": "DL_CHONG_CHOANG",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Dùng dung dịch a giao $5\\%$ thêm muối để giữ đẳng trương và kiềm hóa, lọc, đun sôi $30-40$ phút, đợi nhiệt độ hạ xuống $38°$ thì tiêm từ từ vào mạch máu; thấy huyết áp trở lại bình thường và con vật được cứu sống.",
        "ghi_chu": "Thí nghiệm trên mèo bị gây choáng."
      },
      "source": {
        "source_id": "CT_VT_VN_T962"
      }
    }
