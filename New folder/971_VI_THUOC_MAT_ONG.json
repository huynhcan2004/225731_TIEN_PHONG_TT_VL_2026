      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Chất lỏng sền sệt, vị ngọt. Ong hút mật hoa, chế biến cô đặc. Ong chúa nuôi bằng mật đặc biệt (sữa chúa). Ong thợ lấy mật. Tính chất mật ong thay đổi theo loại hoa.",
        "thanh_phan_hoa_hoc": [],
        "cach_dung_bao_che": "Lấy mật vào mùa xuân, hạ, thu. Cắt tầng ong, phơi nắng. Đun nóng và ép nhẹ."
      }
    }
