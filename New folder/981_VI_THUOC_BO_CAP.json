    ],
    "properties": {
      "bo_phan_dung": "cả con bọ cạp (toàn yết) hoặc chỉ dùng đuôi (yết vĩ)",
      "thu_hai": "Không rõ",
      "che_bien_tho": "Không rõ",
      "lieu_dung_chung": "Nếu dùng thuốc sắc thì ngày dùng $3$ đến $5g$; nếu dùng thuốc bột hay thuốc viên thì chỉ dùng $2$ đến $3g$, chia làm $2$ hay $3$ lần uống.",
      "muc_do_doc": "Có độc",
      "trieu_chung_ngo_doc": "Không rõ",
      "phan_bo": "Trong nước ta có nhiều loài bọ cạp, nhưng cho đến nay ta vẫn phải nhập bọ cạp ở nước ngoài về làm thuốc. Con bọ cạp ở nước ta đã được xác định thuộc chi Buthiurus hoặc chi Heteronetrus. Thực tế ta có thể dùng nhiều loài khác nhau. Vì toàn yết hiện nay ta dùng làm thuốc thuộc loài Buthus martensii Karsch thuộc họ Bọ cạp Buthidae."
    },
    "display_name": "Bọ cạp"
  },
