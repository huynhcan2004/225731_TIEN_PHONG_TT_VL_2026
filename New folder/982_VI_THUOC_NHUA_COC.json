    {
      "from": "VI_THUOC_NHUA_COC",
      "to": "DL_GAY_TE_CUC_BO",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Khi đắp nhựa cóc lên da hay niêm mạc thì lúc đầu thấy có hiện tượng kích thích, sau thấy tê cục bộ."
      },
      "source": {
        "source_id": "CT_VT_VN_T982"
      }
    },
    {
      "from": "VI_THUOC_NHUA_COC",
      "to": "DL_TAC_DONG_TIM",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Trên tim gần giống chất glucozit chữa tim trong dương địa hoàng (Digitalis). Khi tiêm dung dịch loãng nhựa cóc vào màng bụng của ếch thì thấy tim đập chậm lại, dần dần ngừng ở thể tâm thu. Tiêm dung dịch nhựa cóc vào tĩnh mạch chó và mèo gây mê thì thấy tim đập chậm lại, không theo quy luật gì cả, đồng thời huyết áp tăng cao; nếu tiêm liều cao thì tim ngừng đập mà chết. | Nếu nhìn điện tâm đồ của mèo gây mê bằng ête rồi tiêm dung dịch nhựa các thì thấy P-R dài ra, tim đập chậm lại. Nếu như trước khi tiêm nhựa cóc đem cắt hai bên dây vagus (thần kinh phế vị) hoặc tiêm atropin, thì không thấy ảnh hưởng. | Các hợp chất sterolic có tác dụng chủ yếu đối với tim.",
        "ghi_chu": "Trần Khắc Khôi cho rằng độc tính của nhựa cóc là do tác dụng trên thần kinh vagus hoặc trực tiếp trên cơ tim."
      },
      "source": {
        "source_id": "CT_VT_VN_T982"
      }
    },
    {
      "from": "VI_THUOC_NHUA_COC",
      "to": "DL_KICH_THICH_NIEM_MAC_DA_DAY",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Khi uống nhựa cóc, có thể có tác dụng kích thích trên niêm mạc dạ dày và gây nôn như khi dùng dương địa hoàng (Digitalis)."
      },
      "source": {
        "source_id": "CT_VT_VN_T982"
      }
    },
    {
      "from": "VI_THUOC_NHUA_COC",
      "to": "DL_TAC_DONG_CO_TRON_RUOT",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Các hợp chất có nitơ, có tác dụng chủ yếu trên cơ trơn ở ruột và trung tâm thần kinh."
      },
      "source": {
        "source_id": "CT_VT_VN_T982"
      }
    },
    {
      "from": "VI_THUOC_NHUA_COC",
      "to": "DL_VAN_MACH",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "$Bufotalin$ tác dụng vận mạch ở thân như digitalin, làm chậm hô hấp và tăng biên độ. Đối với người, nó làm tăng áp lực tim bóp mà không giảm áp suất tâm dãn (diastolic) do đó biên độ tim tăng lên."
      },
      "source": {
        "source_id": "CT_VT_VN_T982"
      }
    },
    {
      "from": "VI_THUOC_NHUA_COC",
      "to": "DL_TANG_HUYET_AP",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "$Bufotenin$ sẽ gây tăng huyết áp với hiện tượng kéo dài co mạch ở thận. $Bufotenidin$ có tác dụng tăng huyết áp mạnh."
      },
      "source": {
        "source_id": "CT_VT_VN_T982"
      }
    },
