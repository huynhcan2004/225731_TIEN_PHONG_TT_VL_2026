      }
    },
    {
      "from": "VI_THUOC_GIUN_DAT",
      "to": "HC_TERASTRO_LUMBROLYSIN",
      "relation_type": "CO_CHUA_HOAT_CHAT",
      "properties": {
        "mo_ta_chi_tiet": "Năm 1914, Thái Hiệp nghiên cứu giun đất lấy ra được một chất độc gọi là $terastro-lumbrolysin$."
      },
      "source": {
        "source_id": "CT_VT_VN_T993"
      }
    },
    {
      "from": "VI_THUOC_GIUN_DAT",
      "to": "HC_LUMBRIFEBRIN",
      "relation_type": "CO_CHUA_HOAT_CHAT",
      "properties": {
        "mo_ta_chi_tiet": "Năm 1915, Điền Trung Bạn Kết và Ngạch Điền Tấn lại chiết được một chất gọi là $lumbrifebrin$ có lẽ là dẫn xuất của tyrosin."
      },
      "source": {
        "source_id": "CT_VT_VN_T993"
      }
    },
    {
      "from": "VI_THUOC_GIUN_DAT",
      "to": "HC_CHAT_BEO",
      "relation_type": "CO_CHUA_HOAT_CHAT",
      "properties": {
        "mo_ta_chi_tiet": "Năm 1921-1922, hai tác giả Nhật Bản khác Thôn Sơn Nghĩa Ôn và Thanh Sơn Tân Thứ Lang lại báo cáo đã chiết từ giun đất được các chất béo, axit, cholesterin, cholin, những chất do thủy phân các axit amin và axit nucleic như adenin và guanin."
      },
