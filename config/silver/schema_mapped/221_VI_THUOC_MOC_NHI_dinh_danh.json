    "ten_raw": "Mộc nhĩ",
    "ten_khoa_hoc": "Auricularia polytricha Sacc.",
    "ho_thuc_vat": "Mộc nhĩ Auriculariaceae",
    "variants": [],
    "properties": {
      "bo_phan_dung": "Thể quả",
      "phan_bo": "Loại nấm mọc trông giống tai người (mộc: gỗ, nhĩ: tai) mặt ngoài màu nâu nhạt, có lông mịn, mặt trong nhẵn màu nâu sẫm. Thể quả chất keo, thời kỳ đầu hình chén, dần dần biến thành hình cái tai, hoặc hình lá, đại bộ phận phẳng, nhẵn, rất ít khi có nếp nhăn. Bộ phận gốc thường có nếp gấp màu xám đỏ, nhiều khi màu tím.",
      "che_bien_tho": "Không có thông tin"
    },
    "display_name": "Mộc nhĩ"
