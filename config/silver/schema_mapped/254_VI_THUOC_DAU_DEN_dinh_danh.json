    "ten_raw": "Đậu đen",
    "ten_khoa_hoc": "Vigna cylindrica Skeels; Dolichos catjang Burm. f.; Vigna catiang Endl. var.",
    "ho_thuc_vat": "Cánh bướm Fabaceae (Papilionaceae)",
    "variants": [
      "Đậu đen trắng lòng",
      "Đậu đen xanh lòng"
    ],
    "properties": {},
