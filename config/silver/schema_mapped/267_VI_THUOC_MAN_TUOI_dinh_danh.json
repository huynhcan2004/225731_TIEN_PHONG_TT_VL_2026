      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây thảo sống hằng năm, mọc đứng hay mọc bò, cao $20$-$50cm$. Thân màu lục hay hơi đỏ, có lông cứng. Lá mọc đối, không cuống hoặc có cuống rất ngắn, hình mác dài $2$-$10cm$, rộng $0,5$-$2,5cm$, mép có răng cưa rất nhỏ, cả hai mặt đều có lông. Cụm hoa hình đầu, đường kính $6$-$8mm$, màu trắng, mọc ở kẽ lá hay đầu cành. Quả bế hình trứng, hơi dẹt, có 4 cạnh hẹp.",
        "thanh_phan_hoa_hoc": [
          "Trong mần trầu người ta thấy có chất ancaloit $0,075\\%$, chất đắng, tanin và một chất màu vàng."
        ],
        "cach_dung_bao_che": "Khi dùng làm thuốc, người ta nhổ cả cây, rửa sạch dùng tươi hay phơi khô."
      }
    }
