  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T310",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "310"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Còn gọi là thiết thụ, phong mao tùng, phong mao tiêu. Thân hình trụ, cao $2$-$3m$, lá mọc thành vòng, dài tới $2m$, hình lông chim, cuống lá có gai, lá chét dài $15$-$18cm$, rộng $6mm$, nhỏ hơn về phía gốc và phía ngọn, gần mọc đối, nguyên, nhẵn, hình sợi chỉ, mũi có gai đơn, mép cuốn lại, có gân lời. Nón đực hẹp, dài $218cm$, rộng $4cm$, nhị thưa, hơi lợp, hình mũi mác hẹp, dài $30cm$, rộng $6$-$8mm$, gần hình lòng thuyền, ở phía trên mang bao phấn dọc theo mép. Nón cái gồm những lá noãn dài tới $20cm$, có lông màu trắng hơi vàng, có phần không sinh sản rộng chia thành nhiều đài hẹp có ngọn cong và mũi nhọn cứng; noãn có lỏng. Hạt hình trái xoan dẹt, thoạt tiên có lông rồi nhẵn, màu da cam, dài $3cm$ ( Hình 230)."
      }
    }
  ],
