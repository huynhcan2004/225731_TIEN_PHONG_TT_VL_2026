      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Đậu khấu là một loại cỏ mọc lâu năm. Thân rễ có vẩy, từ thân rễ những trụ mang lá và trục mang hoa và quả ló lên mặt đất. Thân mang lá có thể cao $2$-$3m$. Lá mọc so le, không cuống, phiến lá hình mác dài $23cm$, rộng $7,5cm$. Cụm hoa hình bông mọc ở gốc, cả cuống hoa và hoa dài $8cm$; tràng hoa màu vàng, hình ống hẹp, dài $2cm$, trên tràng hoa màu vàng, có điểm tím hay đỏ tía. Quả hình cầu dẹt, màu tím trắng, đường kính $1,5cm$ ( hình 303 ).",
        "thanh_phan_hoa_hoc": [
          "Trong đậu khấu có chừng $2,4\\%$ tinh dầu.",
          "Thành phần chủ yếu của tinh dầu là $d.bocneola$ và $d.campho$."
        ],
        "cach_dung_bao_che": "Khi dùng, bóc vỏ lấy hạt."
      }
    }
