      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây ngưu tất là một loại cỏ xước cho nên người ta nhầm với cây cỏ xước Achyranthes aspera L. Cỏ có thân mảnh, hơi vuông, thường chỉ cao $1m$, cũng có khi tới $2m$. Lá mọc đối có cuống, dài $5$-$12cm$, rộng $2$-$4cm$, phiến lá hình trứng, đầu nhọn, mép nguyên. Cụm hoa mọc thành bông ở đầu cành hoặc kẽ lá Hình 18. Cây ngưu tất - Achyranthes bidentata",
        "thanh_phan_hoa_hoc": [
          "Trong rễ ngưu tất người ta chiết xuất ra một chất saponin, khi thuỷ phân sẽ cho axit oleanic C,H,O, và galactoza, rhamnoza, glucoza. Ngoài ra còn có ecdysteron, inokosteron và muối kali."
        ],
        "cach_dung_bao_che": "Rễ đào về rửa sạch, phơi hoặc sấy khô."
      }
    }
  ],
