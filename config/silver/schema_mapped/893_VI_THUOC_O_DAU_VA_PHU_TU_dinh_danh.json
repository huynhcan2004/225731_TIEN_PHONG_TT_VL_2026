    "properties": {
      "bo_phan_dung": "Rễ củ",
      "thu_hai": "[CT_VT_VN_T895]: Quả thu hoạch vào tháng 7-8",
      "che_bien_tho": "Cách chế biến khác nhau mà ô đầu rất độc, thường chỉ dùng để xoa bóp bên ngoài, còn phụ tử ít độc hơn có thể dùng uống trong với liều khá cao."
    },
    "display_name": "Ô đầu và phụ từ"
