      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Dây leo bằng tua cuốn. Thân nhẵn, có gai. Lá mọc so le, hình bầu dục hay hình trứng, nhẵn, 3 gân chính nổi rõ, dài $6$-$12cm$, rộng $3$-$6cm$. Hoa nhỏ màu vàng lục, mọc thành tán ở nách lá. Quả mọng hình cầu, đường kính $7$-$10mm$, khi chín màu đen.",
        "thanh_phan_hoa_hoc": [
          "Trong củ thanh thất người ta thấy có tinh bột, chất nhựa, axit hữu cơ và tanin."
        ],
        "cach_dung_bao_che": "Thường đào củ về rửa sạch, thái mỏng, phơi sấy khô. Có khi dùng tươi."
      }
    }
  ],
