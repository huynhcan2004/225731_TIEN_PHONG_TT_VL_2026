    "properties": {
      "bo_phan_dung": "cụm hoa và quả",
      "phan_bo": "Sapa (Lào Cai), Tam Đảo (Vĩnh Phúc), Hà Giang, khắp các bãi cỏ, ven đường, bờ ruộng ở khắp các tỉnh miền Bắc nước ta. Còn thấy ở các nước khác như Trung Quốc, Triều Tiên, Nhật Bản và các nước châu Âu.",
      "thu_hai": "Vào mùa hạ, khi một số quả đã chín thì hái cành mang hoa và quả phơi hay sấy khô.",
      "che_bien_tho": "phơi hay sấy khô"
