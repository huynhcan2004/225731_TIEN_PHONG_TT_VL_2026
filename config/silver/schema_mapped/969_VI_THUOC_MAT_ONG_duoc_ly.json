      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Thuốc tắc kẻ không gây hiện tượng dị ứng, dùng chế dưới dạng thuốc tiêm, không gây phản ứng tại chỗ hay toàn thân."
      },
      "source": {
        "source_id": "CT_VT_VN_T969"
      }
    },
