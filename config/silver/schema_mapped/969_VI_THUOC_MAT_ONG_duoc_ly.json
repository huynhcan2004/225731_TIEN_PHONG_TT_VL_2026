      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Thuốc tắc kè làm tăng lượng hồng huyết cầu, tăng huyết sắc tố và không ảnh hưởng tới hệ thống bạch cầu."
      },
      "source": {
        "source_id": "CT_VT_VN_T969"
      }
    },
    {
      "from": "VI_THUOC_MAT_ONG",
