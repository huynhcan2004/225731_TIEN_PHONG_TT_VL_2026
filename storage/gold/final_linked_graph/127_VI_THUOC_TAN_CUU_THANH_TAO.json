    {
      "id": "VT_TAN_CUU_THANH_TAO",
      "label": "ViThuoc",
      "properties": {
        "canonical_name": "Vị thuốc Tân cửu (Thanh táo)",
        "aliases": [
          "tân cửu (thanh táo)",
          "tan cuu (thanh tao)",
