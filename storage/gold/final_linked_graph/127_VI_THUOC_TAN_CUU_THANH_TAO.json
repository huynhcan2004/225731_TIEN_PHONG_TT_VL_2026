        ],
        "search_vector_hint": "Tân cửu (Thanh táo) thuộc nhóm vị thuốc, thường liên quan đến trị ho.",
        "bo_phan_dung": "rễ cây",
        "lieu_dung_chung": "Ngày dùng $6$-$12$g dưới dạng thuốc sắc hay thuốc cao hoặc ngâm rượu.",
        "muc_do_doc": "Không độc",
        "phan_bo": "Trung Quốc (Quảng Đông, Đài Loan, Đông Bắc), Ấn Độ, Triều Tiên, Indonêxya",
        "thu_hai": "quanh năm, tốt nhất vào các tháng 7-8",
        "che_bien_tho": "dùng vỏ thân hay vỏ rễ, rễ, lá hoặc tươi hoặc khô",
        "ten_khoa_hoc": "$Justicia gendarussa L. (Gendarussa vulgaris Nees.); Justicia procumbens L. (Justicia hayatai Merr.)$",
        "ho_thuc_vat": "$Ô rô Acanthaceae$",
        "hinh_thai_chi_tiet": "Cây tần của hay thanh táo là một cây nhỏ cao chừng $1,5m$, cành có màu tím sẫm hay xanh lục, nhẫn, giữa chỗ lá mọc đối có một dòng lông. Lá mọc đối, mang cuống ngắn, phiếu là hình mác thuôn, dài $4-14cm$, rộng $1-2cm$, mép nguyên. Lá thường bị loài nấm Puccinia thwaitesii ăn hại. Mặt lá nhẵn có gân xanh hay màu tím tùy theo cây. Hoa màu trắng hay hơi điểm hồng, có những đốm tía, mọc thành bông ở đầu cành hay kẽ lá phía ngọn. Quả nang dài Cây nhỏ, cao $20-40cm$. Thân vuông, hơi có lông. Lá mọc đối, hình trứng, dài $1-3cm$, rộng $0,5-1,2cm$, mép nguyên hoặc hơi khía răng, hai mặt đều có lông. Hoa nhỏ, màu trắng, mọc thành xim co ở kẽ lá. Quả nang hình trứng dài $10-12mm$, trong chứa 4 hạt. Mùa hoa quả vào mùa hạ ( Hình 71 ).",
        "thanh_phan_hoa_hoc": "['Trong cây thanh táo có chứa một ancaloit gọi là `$justixin$` và một lượng rất ít tinh dầu ($0,001\\\\%$). Hoạt chất khác chưa rõ.']",
        "cach_dung_bao_che": "Người ta dùng vỏ thân hay vỏ rễ, rễ, lá hoặc tươi hoặc khô."
      }
    },
