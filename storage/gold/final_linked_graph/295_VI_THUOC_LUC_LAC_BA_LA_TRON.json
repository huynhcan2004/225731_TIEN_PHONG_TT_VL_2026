        "muc_do_doc": "Không độc",
        "ten_khoa_hoc": "$Crotalaria mucronata Desv.$",
        "ho_thuc_vat": "$Cánh bướm Papilionaceae (Fabaceae)$",
        "hinh_thai_chi_tiet": "Cây bụi, cao khoảng $1$m hay hơn, có cành hơi có lông rạp xuống. Lá có $3$ lá chét, lá chét hình trái xoan ngược nhọn hay gần tù ở góc, tù hoặc có khía ở đỉnh, các lá bên nhỏ hơn, mặt trên nhẵn, mặt dưới có lông ngắn và rạp xuống. Hoa xếp thành chùm giống những vòng giả, có lông ngắn, màu vàng, rất cong. Quả hình trụ. Hạt nhiều, màu nâu nhạt hay vàng da cam, hình thận. Mùa hoa quả: Từ tháng $5$-$12$ (Hình 217).",
        "thanh_phan_hoa_hoc": "['Trong hạt có $mucronatin$ $C_{18}H_{25}ON$, $usaramin$, $mucronatinin$, $retrorsin$ $C_{18}H_{25}ON$ và $nilgirin$.', \"Lá chứa $vitexin$ $C_{21}H_{20}O_{10}$, $vitexin$ $4'$-$O$-$xylozit$ $C_{26}H_{28}O_{14}$.\", 'Thân chứa $apigenin$ $C_{15}H_{10}O_5$.']",
        "lieu_dung_tong_quat": "Còn dùng toàn cây hái tươi."
      }
    }
