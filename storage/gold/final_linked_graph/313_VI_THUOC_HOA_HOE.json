        "ho_thuc_vat": "$Cánh bướm (Papilionaceae). Fabaceae$",
        "thanh_phan_hoa_hoc": "['$Rutin$, $Esculozit$, $Hesperidin$, $Betulin$, $Sophoradiol$ $Rutin$']"
