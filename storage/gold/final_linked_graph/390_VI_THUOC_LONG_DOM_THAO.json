    {
      "id": "VT_LONG_DOM_THAO",
      "label": "ViThuoc",
      "properties": {
        "canonical_name": "Vị thuốc Long đờm thảo",
        "aliases": [
          "longdomthao",
          "long đờm thảo",
          "long dom thao"
        ],
        "search_vector_hint": "Vị thuốc Long đờm thảo thuộc nhóm Vị thuốc, thường liên quan đến thành phần dược liệu.",
        "bo_phan_dung": "thân rễ và rễ",
        "thu_hai": "mùa hoa tháng 9-10, mùa quả tháng 10",
        "che_bien_tho": "phơi hay sấy khô",
        "lieu_dung_chung": "Liều dùng hàng ngày $2-3g$ dưới dạng thuốc sắc hoặc thuốc rượu.",
        "muc_do_doc": "Không độc",
        "ten_khoa_hoc": "$Gentiana scabra Bunge; Gentiana lutea L.$",
        "ho_thuc_vat": "$Long đởm (Gentianaceae)$",
        "hinh_thai_chi_tiet": "Long dom tháo (Gentiana hay Radix Gentianae) là thân rễ và rễ phơi hay sấy khô của cây long đởm Cây long đởm lá một loại cỏ sống lâu năm, cao 35-60cm. Thân rễ ngắn, rễ nhiều, đường kính 2-3mm, vỏ ngoài màu vàng nhạt. Thân mọc đúng, đơn độc hay 2-3 cành, đốt thường ngắn so với chiều dài của lá. Lá mọc đối, không cuống, lá phía dưới thân nhỏ, phía trên to rộng hơn, dài từ 3-8cm, rộng từ $0,4-3cm$. Hoa hình chuông màu lam nhạt hay sẫm, mọc thành chùm không cuống ở đầu cành hoặc ở kẽ những lá phía trên. Mùa hoa tháng 9-10, mùa quả tháng 10 (Hình 281) Ngoài vị long đởm kể trên, trong đông y còn dùng nhiều loại long đởm khác, những vị thuốc gần giống và gồm những rễ nhỏ. Nhưng trong tây y lại dùng một loại khác (Gentiana lutea L.) có hoa màu vàng, rễ to hơn, thái thành từng miếng mỏng, có người dịch nhầm là khổ sâm vì là vị thuốc bổ mà lại đắng. Tất cả những cây này đều chưa thấy ở nước ta.",
        "thanh_phan_hoa_hoc": "['[CT_VT_VN_T391]: Trong long đởm có một glucozit đắng chừng $2\\\\%$ gọi là $gentiopicrin$ và một chất đường gọi là $gentianoza$ chừng $4\\\\%$. Thủy phân $gentiopicrin$ ta sẽ được $gentiogenin$ và glucoza. $Gentianoza$ gồm hai phân tử glucoza và một phân tử fructoza.']"
      }
    },
