    {
      "id": "VT_BACH_TRUAT",
      "label": "ViThuoc",
      "properties": {
        "canonical_name": "Vị thuốc Bạch truật",
        "aliases": [
          "bach truat",
          "bạch truật",
          "bachtruat"
        ],
        "search_vector_hint": "Vị thuốc Bạch truật thuộc nhóm Vị thuốc, thường liên quan đến kiện tỳ, táo thấp.",
        "bo_phan_dung": "rễ phát triển thành củ to và mẫm",
        "lieu_dung_chung": "Ngày dùng 6-12$g$ dưới dạng thuốc sắc.",
        "muc_do_doc": "Không độc",
        "phan_bo": "Trước đây ta phải nhập bạch truật của Trung Quốc. Tại đây người ta trồng nhiều nhất ở Triết Gần đây đã di thực được bạch truật. Nhưng mới bắt đầu đưa ra trồng rộng rãi. Đặc biệt ở nước ta có thể trồng cả ở miền núi cao lạnh và đồng bằng thấp, nóng. Nơi cao lạnh chủ yếu nhân và giữ giống, đồng bằng thu lấy củ.",
        "ten_khoa_hoc": "$Atractylodes macrocephala Koidz.; Atractylis macrocephala (Koidz) Hand. Mazz.; Atractylis ovata Thunb.$",
        "ho_thuc_vat": "$Cúc Compositae$",
        "hinh_thai_chi_tiet": "Bạch truật là một cây mọc lâu năm, cao tới 80cm. Rễ phát triển thành củ to và mẫm. Lá mọc so le, dai. Lá ở phía dưới thân có cuống dài, phiến lá chia làm 3 thùy rõ rệt, cắt sâu, trông gần như lá riêng, lá ở ngọn không chia thùy, cuống ngắn, mép phiến lá có răng cưa đều và nhọn. Cụm hoa hình đầu, lớn, tổng bao hình chuông, phiến tổng bao gồm 7 lớp trông như ngói lợp. Tràng hoa hình ống phía dưới màu trắng, phía trên màu tím đỏ, chia làm 5 thùy hình, sợi dài, 5 nhị (trong những hoa cái ở phía ngoài của cụm hoa có nhị thoái hóa). Bầu nhụy có phủ lông trắng, ở đỉnh mang một chùm lông dài mượt (dùng để phát tán quả nhờ gió)"
      }
    },
