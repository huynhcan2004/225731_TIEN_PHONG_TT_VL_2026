        ],
        "search_vector_hint": "Khiên ngưu thuộc nhóm Vị thuốc, thường liên quan đến thành phần dược liệu.",
        "bo_phan_dung": "hạt",
        "thu_hai": "không đề cập",
        "che_bien_tho": "không đề cập",
        "lieu_dung_chung": "Liều dùng mỗi ngày $2-3g$ tán bột, dùng nước chiêu thuốc. Nếu dùng nhựa khiên ngưu chỉ dùng mỗi ngày 0,20-$0,40g$, có thể dùng tới 0,60-$1,20g$ hoặc $1,50g$.",
        "muc_do_doc": "Có độc",
        "trieu_chung_ngo_doc": "Không đề cập",
        "phan_bo": "Mọc hoang ở nhiều tỉnh nước ta. Còn mọc ở Ấn Độ, Inđônêxia, Thái Lan, Nhật Bản, Philipin, Trung Quốc.",
        "ten_khoa_hoc": "$Ipomoea hederacea Jacq (Pharbitis hederacea Choisy); Pharbitis nil (L.) Choisy$",
        "ho_thuc_vat": "$Bìm bìm (Convolvulaceae)$",
        "hinh_thai_chi_tiet": "Khiên ngưu là một loại dây leo, cuốn, thân mảnh, có điểm những lông hình sao. Lá hình tim, xẻ 3 thuỳ, nhẵn và xanh ở mặt trên, xanh nhạt và có lông ở mặt dưới, dài $14cm$, rộng $12cm$, cuống dài $5-9cm$, gầy, nhẵn. Hoa màu hồng tím hay lam nhạt, lớn, mọc thành xim 1 đến 3 hoa, ở kẽ lá. Quả nang hình cầu, nhẵn, đường kính $8mm$, có 3 ngăn. Hạt 2-4, hình 3 cạnh, lưng khum, hai bên dẹt, nhẵn, nhưng ở tế hơi có lông, màu đen hay trắng tuỳ theo loài, dài $5-8mm$, rộng $3-5mm$. $100$ hạt chỉ nặng chừng $4,5g$ ( Hình 343 ).",
        "thanh_phan_hoa_hoc": "['Trong khiên ngưu có chừng $2\\\\%$ chất glucozit gọi là $phacbitin$ có tác dụng tẩy, ngoài ra còn chừng $11\\\\%$ chất béo và 2 sắc tố cũng là glucozit.', '$Phacbitin$ được cấu tạo bởi các chất sau đây: [CT_VT_VN_T460]: $axit tiglic$, $metyl etylaxetic$, $axit nilic$, $axit ipurolic$, $glucoza$, $ramnoza$, $phacbitin$']",
        "cach_dung_bao_che": "Vào các tháng 7-10, quả chín, người ta hái về, đập lấy hạt phơi khô là được."
      }
    },
