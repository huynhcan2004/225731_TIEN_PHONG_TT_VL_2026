        "search_vector_hint": "Vị thuốc Hy thiêm thuộc nhóm Vị thuốc, thường liên quan đến điều trị phong thấp.",
        "bo_phan_dung": "toàn cây",
        "thu_hai": "không đề cập",
        "che_bien_tho": "không đề cập",
        "lieu_dung_chung": "Ngày dùng 6-12$g$ dưới hình thức thuốc sắc, thuốc viên hay thuốc cao mềm. Có thể tăng tới liều 16$g$ một ngày.",
        "muc_do_doc": "Có độc",
        "trieu_chung_ngo_doc": "Không đề cập",
