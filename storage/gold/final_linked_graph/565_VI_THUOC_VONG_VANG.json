      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Vông vang là một cây thân cỏ cao khoảng 1m, phía gốc hơi thành gỗ và thân hơi có lông. Lá hình tim, có cạnh hoặc chia thùy khá sâu cả hai mặt đều phủ nhiều lông. 5 thuỳ hình ba cạnh, mép có răng cưa, trên có 3-5 gân chính. Hoa màu vàng, mọc đơn độc ở nách lá phía trên, cuống hoa phủ lông và phía sát hoa hơi phình lên. Quả thuôn trên phủ đầy lông trắng nhạt, chiều dài quả $4$-$5cm$, với 5 cạnh, phía trong cũng phủ lông, chứa nhiều hạt hình thận, dẹt, dài $3$-$4mm$, rộng $1$-$2mm$, trên mặt có những đường nhãn đồng tâm xung quanh rốn hạt.",
        "thanh_phan_hoa_hoc": [
          "Hạt chứa dầu mùi xạ hương cho nên trên thị trường thường có tên hạt xạ (graine d’ambrette). Tình dầu đặc ở nhiệt độ thường, màu vàng nhạt, mùi thơm của xạ, thành phần chủ yếu của tinh dầu là chất `$panmitin$`, `$farnesola$` và `$ambretolite$`. Rễ có chứa chất nhày như rễ sâm bố chính."
        ],
        "cach_dung_bao_che": "Chủ yếu người ta dùng hạt làm thuốc hay để chế tinh dầu dùng trong nước hoa. Chất nhầy trong rễ được dùng làm chất dính trong nghề giấy hay làm tinh bột."
      },
      "confidence_score": 0.95
    }
