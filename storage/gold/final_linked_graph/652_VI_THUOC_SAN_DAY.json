    {
      "id": "VT_SAN_DAY",
      "label": "ViThuoc",
      "properties": {
        "canonical_name": "Vị thuốc Sắn dây",
        "aliases": [
          "cat can",
          "cát căn",
          "san day",
          "sắn dây",
          "catcan",
          "sanday"
        ],
        "search_vector_hint": "Vị thuốc Sắn dây thuộc nhóm vị thuốc, thường liên quan đến thanh nhiệt, giải độc.",
        "bo_phan_dung": "rễ phát triển to lên thành củ",
        "lieu_dung_chung": "Ngày dùng 8-20$g$ dưới dạng thuốc sắc, dùng riêng hay phối hợp với những vị thuốc khác.",
        "muc_do_doc": "Không độc",
        "phan_bo": "khắp miền rừng núi nước ta",
        "ten_khoa_hoc": "$Pueraria thomsoni Benth.; Pueraria triloba Mak., Dolichos spicatus Grah.$",
        "ho_thuc_vat": "$Cánh bướm Fabaceae (Papilionaceae).$",
        "hinh_thai_chi_tiet": "Sắn dây là một loại dây leo, có thể dài tới 10m, rễ phát triển to lên thành củ, nhiều bột. Thân cây hơi có lông. Lá kép gồm 3 lá chét; lá chét hình trứng, bản thân lá chét lại chia thành 2-3 thuỳ rõ rệt phiến lá chét dài 7-15cm, rộng 5-12cm có lông nằm rạp trên 2 mặt lá, cuống lá chét giữa dài, cuống 2 lá chét hai bên ngắn hơn. Hoa màu xanh, mọc thành chùm ở kẽ lá. Quả giáp dài 9-10cm, rộng $10mm$, màu vàng nhạt, rất nhiều lông ( Hình 495, Hm 24,3).",
        "thanh_phan_hoa_hoc": "['Trong sắn dây, hiện nay người ta mới chỉ thấy có tinh bột với tỷ lệ $12-15\\\\%$ (tỉnh trên rễ tươi). Mới đây hệ dược của Viện y học Bắc Kinh có tìm thấy trong cát căn có chất $saponozit$.', 'Trong sắn dây, còn thấy $puerarin$ là một flavonozit:', 'Trong lá sắn dây có $asparagin$, $adenin$ và $axit amin$.', 'Trong loài sắn dây Pueraria lobata (Wild) Ohwi có $daidzein$, $daidzein-4’7-diglucozit$.', 'Theo Murakani T., trong cát căn có $puerarin$, $puerarin-7-xylozit$; người ta còn thấy có 4’6\"-0-diaxetyl-$puerarin$.']",
        "cach_dung_bao_che": "Nếu muốn chế bột sắn dây thì giã nhỏ, gạn lấy tinh bột, lọc đi lọc lại nhiều lần, phơi khô."
      }
    },
