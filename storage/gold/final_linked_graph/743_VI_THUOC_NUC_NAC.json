          "mocho蝶",
          "nucnac",
          "nuc nac"
        ],
        "search_vector_hint": "Vị thuốc Núc nác thuộc nhóm thuốc thanh nhiệt, thường liên quan đến điều trị viêm họng.",
        "bo_phan_dung": "vỏ, hạt",
        "lieu_dung_chung": "Ngày uống $2$ đến $3g$ dưới dạng thuốc sắc (để chữa ho) hay sấy khô tán nhỏ (chữa bệnh đau dạ dày).nDùng ngoài tán bột rắc lên vết lở loét mụn nhọt vỡ lâu ngày không liền miệng, không kể liều lượng.nNgày dùng $5$ đến $10g$ vỏ khô dưới dạng thuốc sắc. Dùng ngoài không kể liều lượng.",
        "muc_do_doc": "Không độc",
        "phan_bo": "Khắp nơi ở nước ta, miền Bắc cũng như miền Nam. Còn mọc ở Trung Quốc (Phúc Kiến, Quảng Tây, Vân Nam, Quý Châu, Tứ Xuyên, Hải Nam, Quảng, Đông), Malaixi, Ấn Độ, Lào, Campuchia.",
        "ten_khoa_hoc": "$Oroxylum indicum (L.), Vent (Bignonia indica L., Calosanthes indica Blume); Oroxylum indicum (L.) Vent.$",
        "ho_thuc_vat": "$Chùm ớt Bignoniaceae (Núc nác Bignoniaceae)$",
        "hinh_thai_chi_tiet": "Vỏ núc nác màu nâu nhạt, trên có rất nhiều sẹo của cuống lá cũ, và rất nhiều những đám nhỏ nổi lên, mặt trong khi còn tươi có màu vàng nhạt, không mùi, vị đắng, hơi hắc. Hạt núc nác hình bầu dục, rất mỏng, dẹt ba phía vỏ ngoài phát triển thành màng rất mỏng, trong trông như cánh bướm, màu trắng nâu nhạt, có những đường gần từ hạt toả ra. Chiều dài cả hạt và cánh từ $4$-$7cm$, rộng $2,5$-$4cm$. Nếu chỉ kể hạt không thì chỉ dài $1,5$-$2,5cm$, rộng $1$-$2cm$. Khi bóc màng ngoài thấy rễ phôi và lá mầm rất rõ, mỏng như cánh bướm, dòn. Không mùi, vị hơi đắng. Những hạt khô, màu trắng, nguyên là tốt.",
        "thanh_phan_hoa_hoc": "['Vỏ núc nác chứa một ít `$ancaloit$`, `$tanin$` và một số dẫn xuất `$flavonoit$` ở dạng tự do hay heterozit. Những chất `$flavonoit$` thường thấy là: `$Oroxylin A$`, `$Baicalein$` hay `$noroxylin$`, `$Crysin$`, `$Tetuin$`. Trong hạt núc nác có một chất kiềm màu vàng, một chất dầu béo chứa $80,4\\\\%$ `$axit oleic$`, các `$axit panmitic$`, `$stearic$` và có thể cả `$axitlignoxeric$`.']",
        "lieu_dung_tong_quat": "Không tìm thấy",
        "ghi_chu_bo_sung": "Không tìm thấy",
        "cach_dung_bao_che": "Không tìm thấy"
      }
    },
