    {
      "source": {
        "source_id": "CT_VT_VN_T754",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "754"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây hồng là một cây nhỡ cao chừng $5-6m$, có thể tới $10m$ nhiều cành. Lá mọc so le, có cuống ngắn, dài không quá $1cm$. Phiến lá thuôn hình trứng, dài $7-14cm$, rộng $4-8cm$, mép nguyên hay hơi lượn sóng. Tháng 6 ra hoa màu vàng trắng nhạt. Cây đực, cây cái riêng biệt hoặc có khi hoa đực, hoa cái có trên cùng một cây. Hoa đực mọc từng $2-3$ cái một thành hình tán, hoa cái mọc đơn độc. Tháng $9-10$ ra quả khi chín có màu vàng hay đỏ thẫm.",
        "thanh_phan_hoa_hoc": [
          "Trong tai hồng có các chất tanin đặc biệt bao gồm axit tritecpenic, axit ursolic, oleanolic và axit betulinic.",
          "Trong quả hồng xanh có chất tanin làm cho quả hồng có vị rất chát, khi chín vị chát hầu như mất đi. Khi đó lượng đường có chừng $13-19\\%$ dưới dạng glucoza, sacaroza và fructoza, $1,15-1,60\\%$ chất protein.",
          "[CT_VT_VN_T755]: $manit$, $shibuol$ $C_{14}H_{27}O_7$"
        ],
        "lieu_dung_tong_quat": "Ngày dùng $6-10g$ dưới dạng thuốc sắc hay thuốc bột.",
        "cach_dung_bao_che": "Sau khi ăn hồng, thu lấy tai (đế) phơi hay sấy khô là được."
      },
      "confidence_score": 0.95
    }
  ],
