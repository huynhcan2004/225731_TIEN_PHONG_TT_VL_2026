    {
      "id": "VT_VONG_NEM",
      "label": "ViThuoc",
      "properties": {
        "canonical_name": "Vị thuốc Vông nem",
        "aliases": [
          "vongnem",
          "vông nem",
          "vong nem"
        ],
        "search_vector_hint": "Vông nem thuộc nhóm vị thuốc, thường liên quan đến an thần.",
        "bo_phan_dung": "không rõ",
        "thu_hai": "không rõ",
        "che_bien_tho": "không rõ",
        "lieu_dung_chung": "Người lớn uống 15-20 hạt (tương đương với $0,8$g-$1,8$g) thì có công hiệu. Nếu dùng liều cao ($6$-$15$g) như các sách cổ, cần sao đen đi vì sao đen có lẽ là một hình thức để giảm chất độc đi.",
        "muc_do_doc": "Không độc",
        "trieu_chung_ngo_doc": "Không rõ",
        "phan_bo": "Mọc hoang và được trồng ở khắp nơi trong nước ta để làm hàng rào và lấy lá ăn, hoặc làm cảnh.",
        "ten_khoa_hoc": "$Erythrina orientalis (L) Murr; Erythrina indica Lamk. E, variegata L. Varorientalis (L) Merr.$",
        "ho_thuc_vat": "$Cánh bướm Papilionaceae$",
        "hinh_thai_chi_tiet": "Cây cao từ 10-20m, mọc khắp nơi, nhưng đặc biệt ưa mọc ở ven biển, thân có gai ngắn. Lá gồm 3 lá chét giữa rộng hơn là dài, dài $10-15cm$, hai lá chết hai bên dài hơn rộng hình 3 cạnh. Hoa màu đỏ tươi tụ họp từ 1-3 thành chùm dầy. Quả giáp dài $15-30cm$, đen, hơi hẹp lại ở giữa các hạt. Trong mỗi quả có 5-6 hạt hình thận màu đỏ hoặc nâu, tễ rộng, hình trứng đen có vành trắng (Hình 610, Hm 18,3).",
        "thanh_phan_hoa_hoc": "['Lá và thân đều chứa một ancaloit độc $érytrin$ (Erythrine)', 'Có tác giả còn lấy được chất saponin gọi là $migarin$ ($migarthin$)', 'Trong hạt có ancaloit gọi là $hypaphorin$ Theo một tài liệu khác (Nhật được chín 1940) thành phần chủ yếu là axit $betulinic$ và $betulin$. Ngoài ra còn có nhiều vitamin C.', 'Theo sự nghiên cứu của hệ Dược viện y học Bắc Kinh gần đây, trong nhân hạt táo có $2,52\\\\%$ $saponin$ và có phản ứng $ancaloit$. Theo S. Shibata và cộng sự trong nhân táo có $0,1\\\\%$ $saponin$ bao gồm $jujubozit A$ và $B$ với genin là $jujubogenin$. Trong lá táo có $rutin$ và $quexetin$.']"
      }
    },
