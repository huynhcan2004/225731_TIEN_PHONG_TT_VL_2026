    {
      "id": "VT_BACH_THUOC",
      "label": "ViThuoc",
      "properties": {
        "canonical_name": "Vị thuốc Bạch thược",
        "aliases": [
          "thuoc duoc",
          "kimthuocduoc",
          "kim thuoc duoc",
          "bachthuoc",
          "bach thuoc",
          "kim thược dược",
