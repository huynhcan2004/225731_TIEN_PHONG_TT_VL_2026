    {
      "id": "VT_DUYEN_HO_SACH",
      "label": "ViThuoc",
      "properties": {
        "canonical_name": "Vị thuốc Duyên hồ sách",
        "aliases": [
          "duyenhosach",
          "duyen ho sach",
          "duyên hồ sách"
        ],
        "search_vector_hint": "Vị thuốc Duyên hồ sách thuộc nhóm Vị thuốc, thường liên quan đến điều trị bệnh lý.",
        "bo_phan_dung": "thân củ hình cầu hơi dẹt",
        "lieu_dung_chung": "Dùng trong những trường hợp đau bụng, khí hư, ngày dùng $6-12g$ dưới dạng thuốc sắc hay thuốc bột, thuốc viên. Ngày dùng $3-6g$ dưới dạng thuốc sắc hay thuốc bột.",
        "muc_do_doc": "Không độc",
        "ten_khoa_hoc": "$Corydalis ambigua Ch. et Schl.; Corydalis ambigua Cham. et Schlecht. (C. bulbosa Pers.)$",
        "ho_thuc_vat": "$Thuốc phiện Papaveraceae$",
        "hinh_thai_chi_tiet": "Duyên hồ sách là một loại cỏ sống lâu năm, có thân củ hình cầu hơi dẹt, đường kính $1-2cm$. Lá mọc so le, chia thành nhiều thuỳ sâu, không đều nhau. Hoa màu hồng, trắng hay hơi tím, mọc thành chùm ở ngọn thân. Quả nang chứa nhiều hạt nhỏ màu đen. Mùa hoa vào tháng 4-5. Mùa quả vào tháng 5-6.",
        "thanh_phan_hoa_hoc": "['Từ Duyên hồ sách, người ta chiết được các ancaloit như $corydalin$, $dehydrocorydalin$, $protopin$, $corybulbin$.']",
        "cach_dung_bao_che": "Duyên hồ sách tốt nhất là thu hoạch ở tỉnh Triết Giang. Rễ củ thu hái về rửa sạch, phơi hay sấy khô. Trước khi dùng phải sao tẩm: Muốn có tác dụng hành huyết thì chế với rượu, muốn có tác dụng cầm máu thì tẩm dấm trước khi sao, muốn có tác dụng điều huyết thì sao không, muốn có tác dụng phá huyết thì dùng sống."
      }
    },
