      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cá nóc là tên dành cho nhiều loài cá khác nhau, có thân hình đặc biệt: thân ngắn, vảy kém phát triển, có răng gắn với nhau thành tấm, kém hoạt động, đặc biệt có bụng phình bầu ra. Khi tự vệ, cá nóc hay ngậm hơi lại, làm phồng mình như chiếc bong bóng, rồi ngửa bụng lên trời, lờ đờ trôi theo dòng nước, thỉnh thoảng chỉ hơi vẫy cái đuôi ngắn của nó. Nằm như vậy, cá không sợ giống gì hại nổi, vì mặt dưới lưng cá lởm chởm đầy gai, phía trên, răng cá vừa lớn, vừa sắc như dao, lại quằm vào một cái mỏ như mỏ chim vet.",
        "thanh_phan_hoa_hoc": [
          "$ciguatoxin$, $ciguaterin$, $tetrodotoxin$"
        ],
        "ghi_chu_bo_sung": "Một số gan cá nóc được dùng ép lấy dầu làm thuốc."
      },
