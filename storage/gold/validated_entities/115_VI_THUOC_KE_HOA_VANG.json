{
  "entity": {
    "entity_type": "VI_THUOC",
    "id": "VI_THUOC_KE_HOA_VANG",
    "ten_raw": "Ké hoa vàng",
    "ten_khoa_hoc": "$Sida rhombifolia L.; Sida alnifolia Lour.; Sida cordifolia L.; Xanthium strumarium L.$",
    "ho_thuc_vat": "$Bông Malvaceae; Cúc Asteraceae$",
    "variants": [],
    "properties": {
      "lieu_dung_chung": "[CT_VT_VN_T116]: Ngày dùng 20-40$g$ cây khô hay lá khô. Nếu cây tươi hay lá tươi, ngày dùng 40 đến 80$g$ dưới hình thức thuốc sắc, sao vàng trước khi sắc cho thơm cho dễ uống. Nếu dùng khô chỉ sắc uống ngày 20 đến 40$g$. [CT_VT_VN_T117]: Ngày dùng 6-12$g$ dưới dạng thuốc sắc.",
      "muc_do_doc": "Có độc",
      "phan_bo": "khắp nơi trong nước ta, còn mọc ở Campuchia, Lào, Ấn Độ, Inđônêxia, Trung Quốc (miền Nam và Hải Nam), Malaixia",
      "thu_hai": "có thể thu hái quanh năm, nhưng tốt nhất vào lúc cây đang ra hoa.",
      "che_bien_tho": "người ta hay hải lá cây để dùng tươi. nhưng có khi hái lá hay toàn cây về phơi khô. khi dùng có khi sao vàng để sắc uống."
    },
    "display_name": "Ké hoa vàng",
    "canonical_name": "Ké hoa vàng"
  },
