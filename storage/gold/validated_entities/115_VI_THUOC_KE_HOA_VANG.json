  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T115",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "115"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Đây là một loại cây cỏ cứng, cao $0,4$-$1$m toàn thân đều có lông mịn. Lá hình trứng, đầu lá tù, phía cuống hình tim, mép khía tai bèo, rất nhiều lông mền trắng nhạt, phiến là dài $2,5$-$5$cm, rộng $2$-$3$cm ở phía cuống. Hoa vàng, mọc thành ngà ở đầu cành. Đài có rất nhiều lông ở phía ngoài. Tràng không có lông. Lá noãn $6$-$10$, dài $3,5$mm, có nhiều vân. Hạt có lông ở đầu, dài $3$mm.",
        "thanh_phan_hoa_hoc": [
          "Trong hạt có một ancaloit rất giống $ephedrin$."
        ],
        "cach_dung_bao_che": "Dùng tươi hay khô."
      },
      "confidence_score": 0.95
    }
  ],
