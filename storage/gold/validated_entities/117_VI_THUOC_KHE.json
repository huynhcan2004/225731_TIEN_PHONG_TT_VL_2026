  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T117",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "117"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Khế là cây gỗ cao 4-6m. Lá mọc so le, kép lông chim, đìa lẻ, dài 11-17cm, lá chét gồm 3-5 đôi, nguyên, mềm, hình trứng nhọn, những lá chét ở phía trên lớn hơn đạt tới $8,5cm$ chiều dài, trên $3,5cm$ chiều rộng. Hoa mọc thành chùm xim dài 3-7cm, ở kẽ lá, màu hồng hay tím nhạt. 5 nhị hữu thụ xen kẽ với 5 nhị thoái hoá. Lá noãn 5 họp thành một bầu thượng 5 ô, mỗi ô chứa 4 noãn. Quả mọng có 5 cạnh, vị chua.",
        "thanh_phan_hoa_hoc": [
          "Trong vị khế có các chất đường, vitamin B1, C2, kali oxalat axit. Các chất khác chưa rõ."
        ],
        "ghi_chu_bo_sung": "Vì quả khế có 5 cạnh nên gọi là ngũ liễm (liễm là thu lại, tụ lại)."
      },
      "confidence_score": 0.95
    }
  ],
