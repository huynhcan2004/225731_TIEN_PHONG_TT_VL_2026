  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T117",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "117"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Liên kiều là một cây cao từ 2 đến 4m. Cành non gần như 4 cạnh có nhiều đốt; giữa các đốt thân rỗng, bì không rõ. Lá đơn mọc đối hoặc có khi mọc thành vòng 3 lá, cuống dài 0,80-2cm. Phiến lá hình trứng, dài 3-7cm, rộng 2-4cm, mép có răng cưa không đều, chất lá hơi dài. Hoa màu vàng tươi. Đài và tràng hình ống, trên xẻ thành 4 thuỳ. 2 nhị thấp hơn tràng. Nhuỵ có 2 nuốm. Quả khô, hình trứng dẹt, dài 1,5-2cm, rộng 0,5-1cm, hai bên có cạnh lồi, đầu nhọn, khi chín mở ra như mỏ chim, phía dưới có cuống hay chỉ còn sẹo. Vỏ ngoài màu nâu nhạt. Trong quả có nhiều hạt, nhưng phần lớn rơi vãi đi, chỉ còn sót lại một ít. Mùa hoa tại Trung Quốc: tháng 3-5; mùa quả: tháng 7-8 ( Hình 62, Hm 5,2 )."
      },
      "confidence_score": 0.95
    }
  ],
