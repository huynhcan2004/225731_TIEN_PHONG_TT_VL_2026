    "entity_type": "VI_THUOC",
    "id": "VI_THUOC_TUNG_HUONG",
    "ten_raw": "Tùng hương",
    "ten_khoa_hoc": "$Resina Pini-Colophonium; Pinus massoniana colôphan$",
    "ho_thuc_vat": "$Không rõ$",
    "variants": [],
    "properties": {
      "bo_phan_dung": "không rõ",
      "thu_hai": "không rõ",
      "che_bien_tho": "không rõ",
      "lieu_dung_chung": "Không rõ",
      "muc_do_doc": "Không độc",
      "trieu_chung_ngo_doc": "Không rõ",
      "phan_bo": "Ở Việt Nam, Lào và Cămpuchia có mấy loài sau đây: 1. Thông hai lá còn gọi là thông nhựa (Pinus merkusii Jungh et De Vries) thuộc họ Thông Pinaceae 2. Thông hai lá còn gọi là thông đuôi ngựa (Pinus massoniana Lambert) cùng thuộc họ Thông Pinaceae 3. Ở miền nam Trung Bộ và Cămpuchia còn có thông ba lá (Pinus khasya Royle) thuộc cùng họ Thông Pinaceae Tại Trung quốc, ở Quảng Đông và Phúc Kiến người ta khai thác cây thông đuôi ngựa (mã v tùng) (Pinus massoniana Lambert) và miền bắc Trung Quốc khai thác cây du tùng (Pinu tabulaeformis Carr) thuộc cùng họ. Ở miền Bắc nước ta thông được trồng tập trung nhiều nhất ở Quảng Ninh, người ta ước tính thông chiếm hàng vạn hecta chạy suốt từ đông sang tây, sau đến Thanh Hóa, Nghệ An, Quảng Bình, một ít ở Bắc Cạn, Thái Nguyên. Tại miền Nam, trên cao nguyên Langbiang giữa Phan Rang-Phan Thiết thông chiếm diện tích khoảng chục vạn héc ta Lào, Campuchia cũng đều có. Thống ưa đất cát."
    },
    "display_name": "Tùng hương",
    "canonical_name": "Tùng hương"
  },
