  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T171",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "171"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Sử quân tử là một loại dây leo hay nói cho đúng loại cây mọc tựa vào cây khác, hoặc hàng rào. Lá mọc đối, đơn, nguyên, hình trứng đầu nhọn, phía cuống hơi tròn hình tim, dài $7-9cm$, rộng $4-5cm$, cuống ngắn. Hoa hình ống, lúc đầu màu trắng, sau chuyển hồng và đỏ, mọc thành chùm ở kẽ lá hoặc đầu cành, dài $4-10cm$. Quả khô, hình trứng nhọn, dài $35mm$, dầy $20mm$, có 5 cạnh dọc hình 3 cạnh, có chứa một hạt dài phía dưới hơi rộng, phía đầu hơi mỏng, có 5 đường sống chạy dọc (Hinh 112, Hm 7,3).",
        "thanh_phan_hoa_hoc": [
          "Trong nhân sử quân tử có chứa từ $21-22\\%$ chất dầu béo màu xanh lục nhạt, sền sệt, mùi nhựa, vị nhạt không có tác dụng tẩy giun, Ngoài ra còn chất gồm, các chất hữu cơ, chất đường $19-20\\%$ axit hữu cơ (axit xitric), kali sunfat. Hoạt chất hiện nay chưa xác định."
        ],
        "lieu_dung_tong_quat": "Không đề cập",
        "ghi_chu_bo_sung": "Không đề cập",
        "cach_dung_bao_che": "Không đề cập"
      },
      "confidence_score": 0.95
    }
  ],
