  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T173",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "173"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây keo hay bồ kết dại là một cây nhỡ không có gai, cao độ $2-4$ m, hoặc hơn, lá 2 lần kép lồng chim, có cuống chung dài $12-20cm$, ở phía dưới phình lên và có một hạch ở dưới đuôi cuống phụ đầu tiên. Trên cuống có lông ngắn nằm rạp xuống. Lá chét từ $11-18$ đôi, gần như không cuống, hình liềm, nhỏ ở đầu, dài $10-15mm$, rộng $3-4mm$. Hoa trắng nhiều, hợp thành hình cầu có cuống. Quả giáp dài $13-14cm$, rộng $15mm$, màu nàu, đầu có một mỏ nhọn cứng. Hạt có khoảng $15-20$, hạt dẹt chỉ hơi phồng lên thôi, sắp nghiêng trong quả, dài $7mm$ rộng $4mm$ phẳng nhẵn, màu nâu nhạt, hình bầu dục, hơi lẹm ở phía dưới (Hình 113, Hm 7,2).",
        "thanh_phan_hoa_hoc": [
          "Chứa $12-14\\%$ chất nhầy, chất đường, $4,45\\%$ tro, $21\\%$ prôtit, $5,5\\%$ chất béo và chất $leuxenola$ (còn gọi là $leuxenin$ hay $mimosin$).",
          "Theo Tôminaca (Nhật Bản 1949) trong lá còn chứa một chất glucozit."
        ],
        "ghi_chu_bo_sung": "Ngoài công dụng làm thuốc, hạt còn đang được nghiên cứu làm thức ăn cho súc vật."
      },
      "confidence_score": 0.95
    }
  ],
