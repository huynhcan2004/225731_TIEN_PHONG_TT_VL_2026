  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T206",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "206"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây bụi, cao $2-3m$ có những cành vươn dài, vỏ thân màu vàng xám nhạt, mỗi đốt, dưới chùm lá có gai ba nhánh, dài $1-1,5cm$. Lá mọc thành chùm $3-4$ lá, có khi tới $8$ lá ở một đốt. Cuống lá ngắn $0,5-1cm$, phiến lá nguyên, hình mác, mép có răng cưa to, cứng, dài $16-17cm$, rộng $4-6cm$, mặt trên màu xanh lục nhạt, mặt dưới màu trắng. Hoa màu vàng, mọc thành chùm. Quả mọng hình trái xoan, dài khoảng $1cm$ mọc trên một cuống dài $30-35mm$, khi chín có màu tím đen trong chứa $3, 4$ hạt đen dài $5-6 mm$, rộng $2-3 mm$. Mùa quả ở Sapa: tháng $5-6$.",
        "thanh_phan_hoa_hoc": [
          "Trong thân và rễ hoàng liên gai đều chứa $becberin$. Hàm lượng đạt tới $3-4\\%$.",
          "[CT_VT_VN_T207]: Cây nhỏ, cao $1-2m$. Thân có nhiều cành, có gai. Lá kép lông chim lẻ, gồm $9-15$ lá chét, không cuống, hình trứng hoặc hình mác, dài $3-8cm$, rộng $1-2cm$, mép có răng cưa nhọn, mỗi răng cưa có một gai. Hoa màu vàng, mọc thành chùm ở kẽ lá. Quả mọng hình trứng, dài $7-9mm$, khi chín có màu đen."
        ]
      },
      "confidence_score": 0.95
    }
  ],
