    "ten_raw": "Cỏ sữa nhỏ lá",
    "ten_khoa_hoc": "$Euphorbia thymifolia Burm (E.prostrata Grah); Euphorbia thymifolia L. (E. microphylla Lamk.)$",
    "ho_thuc_vat": "$Thầu dầu Euphorbiaceae$",
    "variants": [
      "Cỏ sữa"
    ],
    "properties": {
      "bo_phan_dung": "toàn cây",
      "thu_hai": "[ct_vt_vn_t215]: hằng ngày dùng",
      "che_bien_tho": "thân nhẵn, màu đỏ nhạt, phân nhánh ngay từ gốc.",
      "lieu_dung_chung": "[CT_VT_VN_T215]: Hằng ngày dùng $15$g đến $20$g (có thể dùng tới $50$g) dưới dạng thuốc sắc. Người lớn có thể dùng tới $100$-$150$g.",
      "muc_do_doc": "Không độc",
      "trieu_chung_ngo_doc": "",
      "phan_bo": "Mọc hoang khắp nơi ở Việt nam. Ưa các đất có sỏi, đá thường thấy ở các kẽ các gạch, sân xi măng dọc đường xe lửa có dải những hòn đá vôi xanh.Hái vào mùa hè. Hái về rửa sạch, sao vàng phơi khô mà dùng. Có mọc ở Ấn Độ, Inđônêxia, Trung Quốc, Philipin. Cây mọc hoang khắp nơi ở Việt Nam, trên các bãi cỏ, ven đường đi, trên các bờ ruộng. Còn thấy mọc ở các nước khác như Ấn Độ, Malaixia, Trung Quốc."
    },
