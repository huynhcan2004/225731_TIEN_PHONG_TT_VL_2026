      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây nhỏ hay nhỡ có thể cao từ 1 đến $9$m. Thân nhẵn. Lá thuôn dài, mọc đối, phía cuống hẹp và nhọn lại, phiến là dài $8$-$20$cm, rộng $2$-$7,5$cm, mặt trên xanh hay xanh sẫm, mặt dưới màu nhạt hơn. Hoa trắng nhạt, mọc thành xim ở đầu cành, Quả hình cầu với đài tồn tại, đường kính $5$-$7$mm, chín có màu đỏ, với hai hạch, mặt hai hạch tiếp giáp nhau phẳng, $5$ sống và rãnh trên lưng hạch. Mỗi hạch chứa một hạt màu đen. Mùa hoa quả: Tháng $5$-$7$ ( Hình $147$ ).",
        "thanh_phan_hoa_hoc": [
          "Sơ bộ thấy rễ và lá đều cho những phản ứng của $ancaloit$."
        ],
        "cach_dung_bao_che": "Người ta dùng rễ và lá thu hái quanh năm. Rễ đào về rửa sạch, thái mỏng phơi hay sấy khô. Lá dùng tươi hay phơi hoặc sấy khô."
      },
