  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T225",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "225"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây thảo, leo cao tới 10m, sống hằng năm. Thân tròn có khía dọc. Lá kép 7 lá chét có cuống chung, xẻ rãnh ở trên, lá chét màu lục nhạt, hình trứng rộng, mềm và nhẵn. Lá kèm sớm rụng. Cụm hoa hình chùm ở nách lá, dựng đứng, có cuống to, mang hoa ở một nửa trên. Hoa to màu trắng hay tím nhạt. Đài hình ống chia 2 môi. Cánh hoa có móng, nhị dính thành 1 bó mang 10 bao phấn màu vàng. Quả lớn, dẹt, hai mép song song, cong hình chữ S. Hạt 10-14, hình bầu dục dài dẹt màu đỏ. Cây ra hoa nhiều lứa từ tháng 6 đến 9, có quả già từ tháng 10-12 (Hình 153).",
        "thanh_phan_hoa_hoc": [
          "Hạt chứa khoảng 20\\% $canavalin$, một ít $canavanin$ men ureaza. Hạt chưa chín chứa $giberellin A₁$ và $A₂$. Trong hạt còn chứa chất gây vón hồng cầu với nồng độ 1:100.000, $concanavalin A$ và $B$, $protit$, $canavanin$, $canalin$, $ureaza$, $canavanin giberellin I$, $canavalia giberellin II$"
        ],
        "ghi_chu_bo_sung": "[CT_VT_VN_T226]: Nhân dân còn hay dùng hạt non nấu ăn vì nếu đợi hạt già thì mặc dầu nấu lâu cũng không mềm dừ, lại hay đau bụng mặc dầu trong hạt không thấy có axit xyanhydric.",
        "cach_dung_bao_che": "Người ta dùng hạt làm thuốc: Quả chín thu hái về, phơi khô lấy hạt, phơi hạt cho thật khô. Hạt dài 2,5-3cm, rộng 1,5-2cm, dày 1cm. Mặt ngoài bóng có những vết nhãn, mép có tễ màu xám đen. dài 1,5-2mm, rộng 2mm."
      },
      "confidence_score": 0.95
    }
  ],
