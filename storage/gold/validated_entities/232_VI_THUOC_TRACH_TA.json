  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T232",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "232"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây trạch tả mọc ở ao và ruộng, cao $0,3$-$1$m. Thân rễ trắng, hình cầu hay hình con quay, thành cụm, lá mọc ở gốc hình trứng thuôn, hay lưỡi mác, phía cuống hơi hẹp lại hình tim. Hoa họp thành tán có cuống dài đều, lưỡng tính có $3$ lá đài màu lục, $3$ cánh hoa trắng hay hơi hồng, nhị nhiều lá noãn rời nhau, xếp xoắn ốc. Quả là một đa bế quả.",
        "thanh_phan_hoa_hoc": [
          "Trong trạch tả, người ta mới phân tích thấy được tinh dầu, chất nhựa $7$\\%, chất prôtit và $23$\\% chất bột. Thành phần hoạt chất chưa rõ."
        ],
        "cach_dung_bao_che": "Hái lấy rễ củ, rửa sạch, hết rễ nhỏ, phơi hoặc sấy khô."
      },
      "confidence_score": 0.95
    }
  ],
