      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây cỏ tranh là một loại cỏ sống dai, thân rễ khỏe chắc. Thân cao $30$-$90$cm, lá hẹp dài $15$-$30$cm, rộng $3$-$6$mm, gân lá ở giữa phát triển, ráp ở mặt trên, nhẵn ở mặt dưới, mép lá sắc. Cụm hoa hình chùy nhưng hình bắp dài $5$-$20$cm màu trắng bạc, bông nhỏ phủ đầy lông nhỏ mềm, rất dài (Hình 160, Hm 10,3).",
        "thanh_phan_hoa_hoc": [
          "Trong thân rễ có $glucoza$, $fructoza$ và $axit hữu cơ$."
        ],
        "ghi_chu_bo_sung": "Lá non dùng cho gia súc ăn, lá già dùng lợp nhà."
      },
      "confidence_score": 0.95
    }
  ],
