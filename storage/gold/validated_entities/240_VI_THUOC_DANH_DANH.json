  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T240",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "240"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Đắng (Khổ)"
        ],
        "tinh": "Hàn",
        "quy_kinh": [
          "K_TAM",
          "K_PHE",
          "K_TAM_TIEU"
        ],
        "cong_nang": "thanh nhiệt (chữa sốt), tả hỏa, lợi tiểu, cầm máu"
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Dành dành là một loại cây nhỏ, cao chừng $1-2m$ thường xanh tốt quanh năm, thân thẳng nhắn. Lá mọc đối, có lá kèm to, mặt trên màu sẫm, bóng. Hoa mọc đơn độc, cánh hoa màu trắng, không cuống, có mùi thơm. Nở vào mùa hè. Quả hình chén với $6-9$ góc, có $2-5$ ngăn, khi chín có màu vàng đỏ, chứa rất nhiều hạt, mùi thơm vị đắng. ( Hình 167, Hm 48,1 ) Cây nhỏ, cao $1-2m$, cành non hơi có lông. Lá mọc đối hoặc mọc vòng $3$ lá một, hình bầu dục hoặc hình trứng, dài $5-10cm$, rộng $2-5cm$, nhẵn bóng. Hoa trắng rất thơm, mọc đơn độc ở đầu cành. Đài hình chén, có $6$ cạnh. Tràng hình ống, phía trên xòe ra $6$ cánh. Quả hình trứng, có cạnh, khi chín màu vàng, chứa rất nhiều hạt (hình 167).",
        "thanh_phan_hoa_hoc": [
          "[CT_VT_VN_T241]: Trong dành dành có một glucozit màu vàng gọi là `$gacdenin$`. Khi thủy phân, cho phần không máu càng giảm nhiều.",
          "Nếu cho uống dành dành liên tục với liều ca vừa đúng rồi mới thắt chặt ống mật thì sẽ thâ kết quả rõ rệt hơn.",
          "Cao rượu dành dành cũng cho kết quả tương tự nhưng so với cao nước thì hơi kém hơn.",
          "Đối với lượng phần tiết nước mật của thỏ, cao nước dành dành cũng có tác dụng như cao rượu",
          "Năm 1954 (Nhật Bản được lý học tạp chí, $5$ (k): $25-26$) một tác giả Nhật Bản nghiên cứu tác dụng muối natri trong dành dành trên chuột bạch nhỏ và thỏ đã chứng minh những chất ở có tác dụng làm tăng lượng mật phân tiết và ủ chế sắc tố mật xuất hiện trong máu.",
          "Tác dụng không sinh. Một số tác giả khá (Trung Hoa y học tạp chí 1952, $38$, $4$ và Trung Hoa bì phu khoa tạp chí 1957, $4$) có nghiên cứu và thấy nước sắc chị tử có tác dụng kháng sinh đối với một số vi trùng."
        ],
        "lieu_dung_tong_quat": "Không có thông tin",
        "ghi_chu_bo_sung": "Không có thông tin",
        "cach_dung_bao_che": "Khi dùng có thể dùng sống (không chế biến gì thêm cả), có thể sao cho hơi sẫm màu hoặc có thể sao cháy đen nhưng chưa thành tro (tồn tính). Trong đông y cho rằng để sống có tác dụng thanh nhiệt (chữa sốt), sao vàng để tả hỏa (nóng trong người), sao đen để cầm máu."
      },
      "confidence_score": 0.95
    }
  ],
