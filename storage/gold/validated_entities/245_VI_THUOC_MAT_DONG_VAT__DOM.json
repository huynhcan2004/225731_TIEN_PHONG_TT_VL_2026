{
  "entity": {
    "entity_type": "VI_THUOC",
    "id": "VI_THUOC_MAT_DONG_VAT_DOM",
    "ten_raw": "Mật động vật - Đởm",
    "variants": [],
    "properties": {
      "phan_bo": "Đông y và tây y đều dùng mật động vật làm thuốc, nhưng tây y chỉ hay dùng mật lợn, mật bò. Còn đông y dùng mật của nhiều loài như mật gấu, mật dê, mật lợn, mật bò, mật trăn, mật rắn, mật gà, mật cá chép v.v... Ngoài ra lại còn dùng cả sỏi trong túi mật của con bò con trâu có bệnh nữa (ngưu hoàng). Một số mật được giới thiệu cùng với con vật (mật rắn) hay giới thiệu riêng (mật gấu); ở đây chúng tôi chỉ giới thiệu mật lợn, mật bò hiện ta còn ít sử dụng."
    },
    "display_name": "Mật động vật - Đởm",
