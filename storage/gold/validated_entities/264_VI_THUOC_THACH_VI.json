  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T264",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "264"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Đắng (Khổ)",
          "Ngọt (Cam)"
        ],
        "tinh": "Hơi hàn",
        "quy_kinh": [
          "K_PHE",
          "K_BANG_QUANG"
        ],
        "cong_nang": "lợi tiểu, thông lâm, thanh thấp nhiệt"
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây thạch vĩ là một loại dương xỉ nhỏ, có thân rễ nằm ngang, dài tới $0,50m$, dày vào khoảng $4mm$, có nhiều nhánh phân chia theo lối đơn túc. Trên thân rễ có nhiều vẩy to, ở mặt dưới từng quãng có nhiều rễ hình sợi, phân nhánh mọc đối. Lá có hai loại; Lá bất thụ và lá hữu thụ. Lá hữu thụ có cuống dài tới $9cm$, phiến lá hình lưỡi mác rộng, dài $11-13cm$, rộng $2-3cm$. Mặt trên nhẵn màu xanh lục, mặt dưới màu nâu nhạt có nhiều ổ tử nang phủ khắp trừ trên gần giữa. Nhìn qua kính hiển vi, ta sẽ thấy ổ tử nang cấu tạo bởi một đám tử nang phân cách nhau bởi những lỏng hình sao có cuống dài. Các lá bất thụ có cuống ngắn hơn, độ $5cm$, với phiển lá hình trái xoan hơi hình mác, dài khoảng $9-11cm$, rộng $3-4cm$. Mặt trên màu lục nhạt, mặt dưới màu lục nâu, gân lá hình lông chim. Cả hai mặt đều nhẫn ( Hình 185 ).",
        "thanh_phan_hoa_hoc": [
          "$phytosterol$, $tanin$ thuộc loại pyrocatechic, những đường khử ôxy, các chất béo và các chất vô cơ $saponozit$, chất tanin, $anthraglucozit$ và phản ứng $flavonozit$."
        ],
        "ghi_chu_bo_sung": "Còn gọi là thạch bì, thạch lan, phi đao kiếm, kim tinh thảo. Cây thạch vĩ mọc hoang ở khắp nơi trong nước ta; thường hay gặp mọc bám trên các cây to hoặc trên các bức tường cũ nát. Còn thấy mọc cả ở Trung Quốc (Phúc Kiến, Đài Loan, Triết Giang, Giang Tô, An Huy, Hoa Nam), Nhật Bản. Người ta dùng lá, toàn cây hay thân rễ tươi hay phơi khô. Có thể thu hái quanh năm."
      },
      "confidence_score": 0.95
    }
  ],
