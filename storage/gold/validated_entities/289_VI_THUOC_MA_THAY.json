      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây có củ to, mọc dưới nước. Thân không có lá, tròn dài, gần như chia đốt, ngoài mặt có khía dọc, phía trong có nhiều vách ngang. Lá được thay thế bởi những bẹ hình trụ. Cụm hoa chỉ gồm có một bông nhỏ màu vàng nâu ở ngọn. Theo Merrill thì loài mã thầy Heleocharis tuberosa (Roxb.) Schult. cũng chỉ là một dạng đã được tuyển chọn và đưa vào trồng trọt của loài Heleocharis plantaginea. Dạng trồng này rất ít khi ra hoa",
        "thanh_phan_hoa_hoc": [
          "Củ mã thầy chứa tới $77\\%$ hydrat cacbon (gồm tinh bột và đường với số lượng bằng nhau), $8\\%$ protein (theo Hooper), nhưng có tác giả lại phân tích thấy trong mã thấy có $60\\%$ tinh bột và $7\\%$ protein và một ít đường (theo Hemmi)."
        ]
      },
      "confidence_score": 0.95
    }
