  "entity": {
    "entity_type": "VI_THUOC",
    "id": "VI_THUOC_TAM_THAT",
    "ten_raw": "Cây tam thất",
    "ten_khoa_hoc": "$Panax Pseudo-ginseng (Burk). F.H.Chen$",
    "ho_thuc_vat": "$Ngũ gia bì Araliaceae$",
    "variants": [
      "Tam thất"
    ],
    "properties": {
      "bo_phan_dung": "lá",
      "lieu_dung_chung": "Theo tài liệu cổ: Tam thất vị ngọt, hơi đắng, tính ôn, vào 2 kinh can và vị. Có tác dụng hành ứ, cầm máu, tiêu thũng dùng chữa thổ huyết, chảy máu cam, lỵ ra máu, đẻ xong máu hôi không sạch, ung thũng, bị đòn tổn thương.",
      "muc_do_doc": "Không độc",
      "phan_bo": "Tam thất (Radix pseudo-ginseng) là rễ phơi khô của cây tam thất. Cây tam thất được trồng từ lâu nhưng với một lượng ít ở tỉnh Hà Giang (Đồng Văn), Lào Cai (Mường Khương, Bát Xát, Phà Lùng), Cao Bằng, .. tại các vùng núi cao $1.200-1.500m$. Cây tam thất còn được trồng ở Trung Quốc: Vân Nam, Quảng Tây, Tứ Xuyên, Hồ Bắc, Giang Tây. Vân Nam trồng nhiều nhất và tam thất Vân Nam được coi là tốt nhất."
    },
    "display_name": "Cây tam thất",
    "canonical_name": "Cây tam thất"
  },
