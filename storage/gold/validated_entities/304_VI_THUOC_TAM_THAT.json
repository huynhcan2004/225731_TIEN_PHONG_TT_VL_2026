    },
    {
      "from": "VI_THUOC_TAM_THAT",
      "to": "DL_TANG_DE_KHANG",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Rễ tam thất có tác dụng làm tăng sức đề kháng của súc vật đối với yếu tố độc hại như liều độc uabain với tim, nhiệt độ môi trường xung quanh quá cao hoặc quá thấp vượt ngoài giới hạn điều hòa của cơ thể."
