      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây mào gà đỏ là một loại cỏ sống lâu năm, cao từ $30cm$ đến $1,5m$ hoặc hơn. Thân đứng, có cành nhẵn. Lá có cuống, phiến lá nguyên hình trứng đầu lá nhọn, phía gốc to rộng hơn lá cây mào gà trắng, Hoa đỏ, vàng hoặc trắng, cuống rất ngắn, mọc thành bông gần như không cuống hình vai với mép loe ra nhăn nheo. Quả hình trứng hay hình cầu. Hạt to hơn hạt mào gà trắng Hình 227. Mào gà đỏ",
        "thanh_phan_hoa_hoc": [
          "Trong hạt có chất béo, các chất khác chưa rõ."
        ]
      },
      "confidence_score": 0.95
    }
