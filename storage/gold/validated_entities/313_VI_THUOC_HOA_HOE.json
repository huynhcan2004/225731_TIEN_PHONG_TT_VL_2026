{
  "entity": {
    "entity_type": "VI_THUOC",
    "id": "VI_THUOC_HOA_HOE",
    "ten_raw": "Cây hoa hòe",
    "ten_khoa_hoc": "$Sophora japonica L.; Styphnolobium japonicum Schott.$",
    "ho_thuc_vat": "$Cánh bướm (Papilionaceae). Fabaceae$",
    "variants": [],
    "properties": {
      "bo_phan_dung": "hoa, quả",
      "thu_hai": "các tháng 7, 8, 9 (hoa); tháng 9-10 (quả).",
      "che_bien_tho": "sơ chế ban đầu.",
      "lieu_dung_chung": "Ngày uống 5-20$g$ dưới dạng thuốc sắc. Ngày dùng 6-12$g$ dưới dạng thuốc sắc hoặc thuốc bột.",
      "muc_do_doc": "Không độc",
      "trieu_chung_ngo_doc": "",
      "phan_bo": "Cây hòe mọc hoang và được trồng khắp nơi ở nước ta, vì trước đây người ta dùng để uống nước cho “mát” và dùng để nhuộm màu vàng.nHàng năm khả năng ta có thể thu mua rất nhiều, thừa dùng trong nước. Nhưng gần đây nhu cầu xuất khẩu lớn cho nên ta đang phát triển trồng.nTrồng bằng hạt hoặc bằng dâm cành. Sau 3-4 năm bắt đầu thu hoạch. Cây sống lâu, càng những năm sau thu hoạch càng cao. Hoa phải hái lúc còn nụ mới chứa nhiều hoạt chất. Phơi hay sấy khô.nHòe được trồng ở khắp nơi trong nước ta để lấy hoa làm thuốc và làm cảnh. Còn được trồng ở nhiều nước khác như Trung Quốc, Triều Tiên. Hòe là một cây dễ trồng, mọc nhanh, không kén đất. Người ta trồng hòe bằng hạt. Trồng sau 5-7 năm có thể thu hoạch hoa. Thường người ta hái những nụ hoa còn chưa nở gọi là hòe mễ (mễ là gạo). Hái vào những ngày trời nắng ráo, đem về phơi hoặc sấy nhẹ đến khô."
    },
    "display_name": "Cây hoa hòe",
    "canonical_name": "Cây hoa hòe"
  },
