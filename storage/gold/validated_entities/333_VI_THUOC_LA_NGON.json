  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T333",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "333"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Đoạn trường thảo hay cây lá ngón là một loại dây mọc leo, thân và cành không có lông, trên thân hơi có khía dọc. Lá mọc đối, hình trứng thuôn dài, hay hơi hình mác, đầu nhọn, phía cuống nhọn hay hơi từ, mép nguyên, bóng, nhẵn, dài $7$-$12cm$, rộng $2,5$-$5,5cm$. Hoa mọc thành xim ở đầu cành hay ở kẽ lá. Cánh hoa màu vàng. Có tài liệu nói hoa màu trắng, nhưng bản thân tôi đã kiểm tra lại là màu vàng (tại Lạng Sơn và các nơi khác: Sapa, Hà Giang). Mùa hoa tháng $6$-$8$-$10$. Quả là một nang, dài, màu nâu hình thon, dài $1cm$, rộng $0,5cm$. Hạt nhỏ, quanh mép có rìa mỏng màu nâu nhạt, hình thận.",
        "thanh_phan_hoa_hoc": [
          "$gelsemin$, $gelmixin$, $sempecvirin$, $sempecvin$, $Kumin$, $Kuminin$, $Kuminixin$, $Kuminidin$ $gelsemin$, $kumin$, $kuminin$, $kaunide C$"
        ],
        "ghi_chu_bo_sung": "Cây lá ngón khá phổ biến ở miền rừng núi Việt Nam. Người ta thường không dùng làm thuốc, mà chỉ dùng để tự tử hay với mục đích đầu độc. Các tỉnh miền núi như Hòa Bình, Hà Tây, Lào Cai, Cao bằng, Tuyên Quang, Hà Giang đều có. Còn có ở một số nước ở vùng nhiệt đới và á nhiệt đới châu Á. Ở Trung Quốc người ta thấy ở Phúc Kiến, Quảng Đông, Quảng Tây, Vân Nam, Tứ Xuyên. Bắc châu Mỹ có loài Gelsemium sempervirens Art. Nhân dân ta hay dùng lá như trên đã nói, trái lại Trung Quốc hay dùng rễ và bán tại các hiệu thuốc để làm thuốc chữa hủi hay chữa bệnh nấm ở tóc (teigne). Cũng được dùng với mục đích đầu độc."
      },
      "confidence_score": 0.95
    }
  ],
