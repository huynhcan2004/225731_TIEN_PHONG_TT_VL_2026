      "confidence_score": 0.75
    },
    {
      "from": "VI_THUOC_CUC_TRU_SAU",
      "to": "DL_KHANG_CON_TRUNG",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Các trừ sâu tác dụng rất mạnh đối với nhiều loại sâu bọ, ít loại sâu bọ không bị tác dụng của nó. Nhưng tác dụng không đồng đều, có con bị ngộ độc tức thời, có con bị từ từ nhưng cũng có loại không bị ảnh hưởng. Muốn có tác dụng bột cúc trừ sâu phải được tán hết sức mịn."
      },
