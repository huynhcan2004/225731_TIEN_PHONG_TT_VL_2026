    {
      "from": "VI_THUOC_CHO_CURARO",
      "to": "DL_DOC_TINH",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Curarơ có độ độc rất cao, nhưng gần như không độc nếu uống, chỉ khi nào có vết sây sát thì chất độc vào máu và hầu như chết tức khắc. Thịt thú rừng chết do chất độc curarơ ăn được, thịt mềm chứ không co cứng.",
        "ghi_chu": "Curarơ uống không gây độc do chất curarơ bị phá hủy ở dạ dày và bị bài tiết rất mau qua nước tiểu, saponin và natri oleat Curin giúp sự hấp thụ của curarơ và gây độc, nhưng nếu curarơ vào máu thì gây ngộ độc ngay."
      },
      "source": {
        "source_id": "CT_VT_VN_T351",
        "all_sources": [
          "CT_VT_VN_T351"
        ]
      },
      "confidence_score": 0.75
    },
