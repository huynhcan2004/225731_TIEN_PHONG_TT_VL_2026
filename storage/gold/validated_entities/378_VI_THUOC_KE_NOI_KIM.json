      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Kê nội kim là lớp màng màu vàng phủ mặt trong của mề hay dạ dày con gà Gallus domesticus Brisson thuộc họ Phasianidae. Màng tốt có màu vàng nâu, trên mặt có những vết nhãn dọc, chất dòn, dễ vỡ vụn, vết bẻ vụn có cạnh bóng. Toàn màng mề gà dài chừng $3,5cm$, rộng $3cm$, dày chừng $5mm$.",
        "thanh_phan_hoa_hoc": [
          "Trong kê nội kim có chất prôtit và chất vị kích tố (ventriculin). Các chất khác chưa rõ."
        ],
        "lieu_dung_tong_quat": "Chưa rõ",
        "ghi_chu_bo_sung": "Có người nói không rửa, nhưng thực tế phải rửa nhưng nhẹ tay để thức ăn còn sót lại trôi hết.",
        "cach_dung_bao_che": "Chưa rõ"
      },
      "confidence_score": 0.95
    }
