  "entity": {
    "entity_type": "VI_THUOC",
    "id": "VI_THUOC_HOAC_HUONG",
    "ten_raw": "Hoặc hương",
    "ten_khoa_hoc": "$Pogostemon cablin (Blanco) Benth.; Agastache rugosa (Fisch. et Mey) O. Kuntze Pogostemon cablin (Blanco) Benth. (Pogostemon patchouly Pellet)$",
    "ho_thuc_vat": "$Hoa môi Lamiaceae (Labiatae)$",
    "variants": [
      "quảng hoắc hương"
    ],
    "properties": {
      "bo_phan_dung": "toàn cây",
      "thu_hai": "không đề cập",
      "che_bien_tho": "không đề cập",
      "lieu_dung_chung": "Ngày dùng 6-12$g$ dưới dạng thuốc sắc hay thuốc bột, dùng riêng hay phối hợp với vị thuốc khác.",
      "muc_do_doc": "Không độc",
      "trieu_chung_ngo_doc": "Không đề cập",
      "phan_bo": "Cây hoắc hương được trồng nhiều nơi ở miền Bắc nước ta, chủ yếu lấy lá và cành làm thuốc. Nhiều nhất tại vùng Kim Sơn (Hà Nam), Hưng Yên. Tại Hà Nội, vườn thuốc Văn Điển có trồng thử. Thường trồng bằng giam cành, vì cây không có hoa quả. Tại các nước khác tại vùng nhiệt đới châu Á và châu Phi, hoắc hương được trồng rất qui mô để lấy lá cất tinh dầu. Những nước sản xuất hoắc hương nhiều nhất hiện nay là Ấn Độ, Malaixia, Philippin, Mangat, Indônêxya."
    },
    "display_name": "Hoắc hương",
    "canonical_name": "Hoặc hương"
  },
