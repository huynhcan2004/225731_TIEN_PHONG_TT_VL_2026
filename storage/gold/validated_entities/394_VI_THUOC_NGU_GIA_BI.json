      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây nhỏ, nhiều gai, cao $2-3m$. Lá kép chân vịt, $3-5$ lá chét hình bầu dục. Hoa mọc thành tán ở đầu cành, màu vàng xanh. Quả mọng, hình cầu, đường kính $2,5mm$, màu đen khi chín.",
        "thanh_phan_hoa_hoc": [],
        "lieu_dung_tong_quat": "Không rõ",
        "ghi_chu_bo_sung": "Ngoài vị trên ra, tên ngũ gia bì còn chỉ nhiều vị khác nhau. Cần chú ý tránh nhầm lẫn."
      },
      "confidence_score": 0.95
    }
