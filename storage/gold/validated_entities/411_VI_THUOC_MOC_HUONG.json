  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T411",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "411"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây quảng mộc hương hay vân mộc hương là một cây sống lâu năm, rễ to mẫm, đường kính có thể đạt tới hơn $5cm$, vỏ ngoài màu nâu nhạt. Phía gốc có lá hình 3 cạnh tròn, dài $12-30cm$, rộng $6-15cm$, cuống dài $20-30cm$ có dìa, mép lá nguyên và hơi lượn sóng, hai mặt đều có lông, mặt dưới nhiều hơn. Trên thân cũng có lá hình 3 cạnh, nhưng càng lên trên kích thước lá càng nhỏ dần, mép có răng cưa, cuống lá càng lên cao càng ngắn lại, phía trên cùng lá gần như không cuống hay có khi như ôm lấy thân cây. Hoa hình đầu, màu lam tím. Quả bế, hơi dẹt và cong queo, màu nâu nhạt, có những đốm màu tím. Mùa hoa vào các tháng 7-9, mùa quả vào các tháng 8-10. Cây thổ mộc hương cũng là một cây sống lâu năm, cao $0,50-1,50m$. Phía gốc có lá to, dài tới $40cm$, trên thân có lá mọc so le nhỏ hơn, dài $10-30cm$, phía cuống có hai tai ôm lấy thân, mép có răng cưa không đều. Cụm hoa hình đầu, hoa màu vàng. Quả bế, dài $4mm$, trên có vân dọc.",
        "thanh_phan_hoa_hoc": [
          "tinh dầu",
          "chất nhựa sausurin (ancaloit)",
          "chất inulin",
          "$aplotaxen$",
          "$B costen$",
          "chất $costus lacton$",
          "chất $dihydrocostus lacton$",
          "axit đặc biệt của vân mộc hương (costus axit)",
          "rượu $costola$",
          "inulin",
          "$anantol$",
          "chất $helenin$ hay long não mộc hương (camphre d’aunée)",
          "lactonisoalantic",
          "helenin"
        ]
      },
      "confidence_score": 0.95
    }
