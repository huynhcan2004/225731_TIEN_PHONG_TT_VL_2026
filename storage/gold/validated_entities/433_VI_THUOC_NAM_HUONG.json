      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "tử của nấm hương hoang dại, trại đã nhân và phát triển giống nhanh, rẻ, chủ động. Trại cũng đã nghiên cứu những loại gỗ có thể dùng để cấy nấm, điều kiện tự nhiên, thời vụ và kỹ thuật cấy nấm. Theo báo cáo của Lào Cai thì trong năm 1973, hợp tác xã Xeo Mí tỉ của người Mèo huyện Sapa đã cấy $18.600m$ gỗ nấm với dự kiến xuân 1974 thu hoạch đợt đầu. Năm 1974, Sapa cấy 10 vạn mét gỗ nấm, để cùng với vùng cao huyện Bát xát năm 1974, toàn tỉnh thu khoảng 30 tấn nấm hương (tính trên khúc cây dài $1m$, một năm thu được $1kg$ nấm tươi).",
        "thanh_phan_hoa_hoc": [
          "Trong $100g$ nấm đã sấy khô trung bình có $12,5g$ chất đạm; $1,6g$ chất béo; $60g$ chất đường; $16mg$ canxi; $240mg$ lân và $3,9mg$ sắt. Những chất khác chưa rõ."
        ]
      },
      "confidence_score": 0.95
    }
