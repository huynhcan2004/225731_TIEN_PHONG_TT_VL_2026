    "ten_raw": "Thìa là",
    "ten_khoa_hoc": "$Anethum graveolens L.; Peucedanum graveolens Benth. et Hook.$",
    "ho_thuc_vat": "$Hoa tán Apiaceae (Umbelliferae)$",
    "variants": [
      "Quả thìa là (nhân dân vẫn gọi nhầm là hạt thìa là)"
