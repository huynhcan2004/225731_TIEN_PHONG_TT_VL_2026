  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T449",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "449"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Sim là một cây nhỏ cao $1-2$m có khi tới $3$m, cành $4$ cạnh, vỏ thân róc thành từng mảng. Lá mọc đối, hình thuôn, hơi hẹp ở phía cuống, phía đầu tù, hơi rộng, dài $4-7$cm, rộng $2-4$cm, khi già thì nhẵn ở mặt trên, có lông mịn ở mặt dưới, phiến lá dày, mép hơi cong xuống, có $3$ gân chính, cuống có lông mịn, dài $4-7$mm. Hoa màu hồng tím, mọc đơn độc hoặc từng $3$ cái một ở kẽ lá. Quả mọng màu tím sẫm, mẫm. Hạt nhiều hình móng ngựa.",
        "thanh_phan_hoa_hoc": [
          "Quả sim có vị ngọt chát, mùi thơm. Chưa được nghiên cứu. Sơ bộ mới thấy sắc tố antoxyanozit, tanin, đường.",
          "Lá và búp sim có chứa nhiều tanin."
        ],
        "lieu_dung_tong_quat": "Không có",
        "ghi_chu_bo_sung": "Không có",
        "cach_dung_bao_che": "Không có"
      },
      "confidence_score": 0.95
    }
  ],
