  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T462",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "462"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây đại là một cây nhỡ, cao $3-7m$, cành mẫm, to. Lá mọc so le sít nhau, thường tập trung ở đầu cành; lá dày, nguyên, dài $15-35cm$, rộng $5-10cm$ hai đầu đều hẹp nhọn, mặt nhẵn bóng, gần giữa nổi rõ. Hoa màu trắng, rất thơm, mặt trong ở phía dưới màu vàng dài $4-5cm$. Quả đại dài hình trụ, dài $12cm$. Mùa hoa ở miền Bắc tháng $4-8$ Đại là một cây to, cao $15-20m$, thân mập, nhiều cành, mềm, vỏ xám trắng. Lá mọc so le, thường tập trung ở đầu cành, hình mác dài $20-40cm$, rộng $7-15cm$, đầu nhọn, gốc thuôn, nhẵn, gân nổi rõ. Hoa to, trắng, họng vàng, rất thơm, cánh hoa dầy, hơi tù. Quả ít thấy, quả gồm hai đại dài $15-20cm$. Hạt có cánh mỏng.",
        "thanh_phan_hoa_hoc": [
          "Trong vỏ thân, Peckolt và Geuther đã tìm thấy một glucozit gọi là `$agoniadin$` $Agoniadin$",
          "Oudman còn chiết được từ nhựa cây một axit gọi là axit plumeric."
        ],
        "cach_dung_bao_che": "Vỏ thân đẽo về sao vàng mà dùng, có khi phơi khô để dành. Vỏ rễ cũng dùng như vỏ thân. Hoa đại hái về, phơi khô. Ngoài ra còn dùng nụ hoa và lá tươi."
      },
      "confidence_score": 0.95
    }
  ],
