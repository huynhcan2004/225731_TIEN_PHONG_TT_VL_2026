    "ten_raw": "Lô hội",
    "ten_khoa_hoc": "$Aloe vera Livar. sinensis Berger; Aloe perfoliata Lour. (non L.), Aloe barbadensis Mill.var.sinensis Haw.; Aloe vulgaris Lamk.; Aloe ferox L.; Aloe perryi Bak.; Aloe maculata Forsk.$",
    "ho_thuc_vat": "$Họ Hành tỏi Liliaceae$",
    "variants": [
      "long thủ",
      "lưu hội"
    ],
    "properties": {
      "bo_phan_dung": "lá",
      "thu_hai": "không có thông tin",
      "che_bien_tho": "bóc vỏ cứng ngoài, cắt thành từng miếng nhỏ",
      "lieu_dung_chung": "Với liều nhỏ dùng giúp sự tiêu hoá, ăn uống không tiêu. Với liều lớn dùng làm thuốc chữa những bệnh nhức đầu khó chữa, sung huyết phổi, sung huyết các phủ tạng. Còn dùng làm thuốc tẩy hay nhuận tràng. Nên dùng sau bữa ăn tác dụng sẽ dịu và mau hơn. Liều dùng hàng ngày: Giúp sự tiêu hoá: $0,05$-$0,1$g. Tẩy: $0,15$-$2$g. Dưới dạng thuốc viên hay nước dịch.",
      "muc_do_doc": "Không độc",
      "trieu_chung_ngo_doc": "Không có thông tin",
      "phan_bo": "đồng châu Phi (từ nam chí bắc đều có), Ấn Độ, Châu Mỹ. Tại nước ta, cây lô hội mọc hoang ở bờ biển những tỉnh Ninh Thuận (Phan Rang, Phan Ri) và Bình Thuận. Ở miền Bắc được trồng làm cảnh nhưng ít hơn."
    },
