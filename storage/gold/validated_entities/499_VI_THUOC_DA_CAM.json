      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây bụi-trườn, thường cuốn vào cây khác, dài $1$-$2$m. Thân hình trụ, đốt phình to. Lá đơn mọc đối, hình bầu dục, đầu nhọn, dài $5$-$15$cm, rộng $3$-$6$cm. Cụm hoa xim phân đôi tụ thành hình cầu ở đầu cành, hoa hình ống nhỏ màu trắng. Quả rất nhỏ xếp thành hình cầu. Có 4 loại: thân tím hoặc thân xanh, chia ra loại nhiều lông hoặc ít lông.",
        "thanh_phan_hoa_hoc": [
          "Chứa $tanin$, $ancaloit$, $saponin$.",
          "Rễ có $anthra-glucozit$."
        ],
        "ghi_chu_bo_sung": "Trừ bỏ rễ vì tác dụng kém hơn."
      },
      "confidence_score": 0.95
    }
  ],
