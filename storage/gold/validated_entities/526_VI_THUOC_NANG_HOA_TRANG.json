      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Náng hoa trắng là một loại cỏ, có hành hình đầu, đường kính đạt tới $10cm$ hay hơn, thuôn dài tới $12cm$ hay hơn nữa. Lá hình bản dài, nhiều, mọc ở gốc, phiến lá hình mác dài, mặt trên hõm thành rãnh, mép nguyên, chiều dài $1-1,20m$, chiều rộng $5-10cm$. Cụm hoa hình tán, gồm $6-12$ hoa màu trắng, to, về chiều có mùi thơm dễ chịu. Tán hoa được mang trên một cán dài $40-60cm$, dẹt, đường kính bằng ngón tay, có mo bao bọc dài $8-10cm$. Nhị thò ra ngoài. Quả gần hình cầu, đường kính $3-5cm$, chỉ có một ngăn và một hạt.",
        "thanh_phan_hoa_hoc": [
          "Trong cây náng hoa trắng có chất ancaloit gọi là lycorin. Ngoài ra còn những ancaloit có cấu tạo tương tự. Nghiên cứu thành phần hoá học trong cây náng hoa trắng ở Việt Nam, thấy ancaloit được phân phối cả lá, hoa, dò và quả."
        ],
        "cach_dung_bao_che": "Hái về dùng ngay, không phải chế biến gì cả."
      },
      "confidence_score": 0.95
    }
