  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T528",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "528"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Hoa mọc thành tán gồm 6-18 hoa, trên một cán hoa dài $30-60cm$. Cánh hoa màu trắng có điểm màu tím đỏ, từ thân hành mọc rất nhiều củ con có thể tách ra để trồng riêng dễ dàng (Hình 393, Hm 25,4).",
        "thanh_phan_hoa_hoc": [
          "Chứa nhiều ancaloit quan trọng. Năm 1984, Ghosal phân lập được glucoancaloit **latisolin** và aglycon **latisodin**. Thân hành chứa **pratorimin**, **pratosin**, **ambelin** và **lycorin**. Đặc biệt, các dẫn chất **crinafolin** và **crinafolidin** được công bố có tác dụng chống ung thư. Dịch ép cán hoa chứa **2-epilycorin** và **2-epipancrassidin**."
        ],
        "lieu_dung_tong_quat": "lá (tươi, phơi khô hoặc sao vàng)"
      },
      "confidence_score": 0.95
    }
  ],
