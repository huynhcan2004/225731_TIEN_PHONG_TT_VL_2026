    "id": "VI_THUOC_TAM_DUOT",
    "ten_raw": "Tẩm duột",
    "ten_khoa_hoc": "$Phyllanthus distichus Muell, Arg.; Phyllanthus acidus Skeels, Cicca disticha L.$",
    "ho_thuc_vat": "$Thầu dầu Euphorbiaceae$",
    "variants": [
      "chùm ruột",
      "chùm giuột",
      "tầm ruộc",
      "mak nhôm (Vientian)"
    ],
    "properties": {
      "bo_phan_dung": "[ct_vt_vn_t533]: tầm duột là một cây nhỏ, thân nhẵn. cành có vỏ màu xám nhạt, trên có nhiều vết sẹo của lá cũ. cành non màu xanh nhạt nhẵn. lá mềm, mỏng, mặt trên màu xanh nhạt, mặt dưới màu nhạt hơn, dài $4$-$5$cm, rộng $18$-$20$mm, phía cuống tù hay hơi tròn, đầu phiến nhọn. hoa mọc thành xim đơm nhị lệ trên những cành gầy nhỏ, dài $6$-$15$cm, tụ thành từng cụm $4$-$7$ hoa trên những mấu tròn, ở kẽ những lá đã rụng. quả nang, $4$ mảnh, khi chín có màu đen nhạt, đường kính $5$mm có đài hơi đồng trưởng, cuống quả dài chừng $7$mm.",
      "muc_do_doc": "Không độc",
      "phan_bo": "Thường mọc hoang và được trồng ở miền Nam để ăn quả. Có mọc và được trồng ở Lào. Tại miền Bắc (Hà Nội), một vài nhà cũng trồng để làm cảnh. Chúng tôi chưa thấy cây mọc hoang. Còn mọc ở nhiều nơi vùng nhiệt đới châu Á (Malaixia, Ấn Độ, Inđônêxia, Philipin) và ở đảo Mangat.",
      "lieu_dung_chung": "Người ta còn dùng các bộ phận khác làm thuốc như vỏ thân, rễ, lá."
    },
    "display_name": "Tẩm duột",
    "canonical_name": "Tẩm duột"
  },
