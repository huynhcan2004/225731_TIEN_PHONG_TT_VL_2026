  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T555",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "555"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Ban là một loại cỏ nhỏ, thân nhỏ mang nhiều cành, cao chừng $10$-$20cm$, thân nhẵn. Lá mọc đối, hình bầu dục, không cuống, trên phiến có những điểm chấm nhỏ, soi lên sáng lại càng rõ. Phiến lá dài $7$-$10mm$, rộng $3$-$5mm$. Hoa nhỏ mọc màu vàng, mọc đơn độc ở kẽ lá, có cuống dài $4$-$5mm$. Lá bắc và lá đài nhẵn (do đó khác loài Hypericum nepalense). Quả nang hình trứng, dài $4mm$, mở bằng $3$ van dọc, thai tòa trắc mô ở cạnh các van. Hạt hình trụ, hơi thon có vạch dọc, chiều dài chừng $1mm$ ( Hình $418$).",
        "thanh_phan_hoa_hoc": [
          "[CT_VT_VN_T556]: $imanin$, $imanin A$ và $novoimanin$."
        ]
      },
      "confidence_score": 0.95
    }
  ],
