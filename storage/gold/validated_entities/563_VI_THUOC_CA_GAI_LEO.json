      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cà gai leo thuộc loại cây nhỡ leo, thân dài $0,60$-$1$m hay hơn, rất nhiều gai, cành xòa rộng, trên phủ lông hình sao. Lá hình trứng hay thuôn, phía gốc lá hình rìu hay hơi tròn, mép nguyên hay hơi lượn và khía thùy, hai mặt, nhất là mặt dưới phủ lông trắng nhạt, phiến dài $3$-$4$cm, rộng $12$-$20$mm, có gai, cuống dài $4$-$5$mm. Hoa tím nhạt, nhị vàng, họp thành xim gồm $2$-$5$ hoa. Quả hình cầu, khi chín có màu vàng, bóng, nhẵn, đường kính $5$-$7$mm. Hạt màu vàng, hình thận, có mạng, dài $4$mm, rộng $2$mm.",
        "thanh_phan_hoa_hoc": [
          "Toàn cây và nhiều nhất ở rễ có $ancaloit$. Trong rễ còn có tinh bột, $saponozit$, $flavonozit$ $solasodin$, $solasodinon$..."
        ],
        "lieu_dung_tong_quat": "Chưa rõ",
        "ghi_chu_bo_sung": "Không phải chế biến gì khác.",
        "cach_dung_bao_che": "Thường người ta đào rễ quanh năm, rửa sạch thái mỏng phơi hay sấy khô làm thuốc."
      },
      "confidence_score": 0.95
