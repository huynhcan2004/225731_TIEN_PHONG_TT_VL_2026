  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T575",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "575"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây thuộc thảo, mọc đứng, có lông, có thể cao tới 1m. Thân mập, có rãnh, khía rõ rệt. Lá dài, dày, có răng cưa to, hai mặt đều có lông. Cuống lá có cánh. Ở góc cuống lá có hai tai nhỏ trông như lá kèn. Cụm hoa đầu, đồng giao, mọc thành gù kép, mỗi gù con gồm 1-3 đầu. Tràng mảnh chia làm 4 thùy, 4 nhị. Bầu hình trụ. Quả hình trụ, mang một chùm lông trắng ở đỉnh. Mùa hoa: mùa hè Cây thảo sống dai, có thân mọc bò, bén rễ ở các mấu. Lá mọc so le, hình trứng hay bầu dục, dài 5-7cm, rộng 2-4cm, gốc hình tim, mép có răng cưa không đều, mặt trên màu lục sẫm, mặt dưới màu tím tía. Cụm hoa hình đầu, màu vàng. Quả bế có lông mềm màu trắng.",
        "thanh_phan_hoa_hoc": [
          "Trong rau tàu bay non có tới $93,1\\%$ nước, $2,3-2,5\\%$ protit, $1,7-1,9\\%$gluxit, $1,6\\%$ xenluloza, $0,9\\%$ tro, $81mg\\%$ canxi, $25mg\\%$ P. $3,$4mg$\\%$ $caroten$, $10mg\\%$ vitamin C."
        ],
        "ghi_chu_bo_sung": "Lá có mùi thơm, có thể dùng nấu canh, ăn được. Khoảng từ tháng 3 đến tháng 7 tuy cây đã ra hoa nhưng vẫn có thể hái lá non ăn được."
      },
      "confidence_score": 0.95
    }
  ],
