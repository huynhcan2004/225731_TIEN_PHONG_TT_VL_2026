  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T578",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "578"
      },
