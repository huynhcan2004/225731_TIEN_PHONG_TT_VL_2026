      "source": {
        "source_id": "CT_VT_VN_T57",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "57"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Ngọt (Cam)"
        ],
        "tinh": "Hàn"
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây gai nói đây là cây mà lá ta vẫn dùng làm bánh gai ăn và sợi để dệt làm lưới đánh cá. Cây sống lâu năm, có thể cao tới 1,5-2m. Lá lớn, mọc so le, hình tim, dài 7-15cm, rộng 4-8cm mép có răng cưa, đáy lá hình tim hay hơi tròn, mặt dưới trắng vì có nhiều lòng trắng, mặt trên có màu lục sẫm, đáp, có 3 gần từ cuống phát ra. Hoa đơn tính cùng gốc. Hoa đực có 4 lá đài và 4 nhị. Hoa cái có đài hợp chia làm 3 răng. Quả bế mang đài tồn tại (Hình 13, Hm 5,3).",
        "thanh_phan_hoa_hoc": [],
        "lieu_dung_tong_quat": "Người ta dùng củ gai (Radix Boehmeriae) là rễ phơi hay sấy khô của cây gai."
      },
      "confidence_score": 0.95
    }
  ],
