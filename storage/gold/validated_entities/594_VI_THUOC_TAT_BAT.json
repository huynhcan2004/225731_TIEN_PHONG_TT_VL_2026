  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T594",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "594"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Cay (Tân)"
        ],
        "tinh": "Ôn",
        "quy_kinh": [
          "K_VI",
          "K_DAI_TRANG"
        ]
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây bò ở phần gốc, cành mang hoa, thẳng đứng không lông. Lá có cuống ngắn, phiến lá hình trứng thuôn, nhọn ở đỉnh, hình tim ở gốc lá, cuống lá hơi phủ lông, có bẹ ở gốc. Hoa đơn tính, mọc thành bông. Bông đực có trục nhẵn, lá bắc tròn nhị 2, chỉ nhị rất ngắn, bao phấn hình bầu dục. Bông cái ngắn hơn, trục cũng không có lông, lá bắc tròn có cuống ngắn. Bầu mang 3 nhụy hình trứng nhọn đầu. Quả mọng. Mùa ra hoa: tháng 3",
        "thanh_phan_hoa_hoc": [
          "Trong tất bạt có `$piperin$`, `$n-izobutyldeca-trans$`, `$2-trans4-dienamide$` `$sesamin$`. Ngoài ra còn chứa 0,25\\% tinh dầu, và chất béo.",
          "Trong thân tất bạt có 0,15-0,18\\% `$piperin$`, `$22,23- dihydrostigmasterol$`, một ít `$ancaloit$`.",
          "Trong rễ có `$piplartin$`, `$piperlongumin$`."
        ],
        "lieu_dung_tong_quat": "Không có",
        "ghi_chu_bo_sung": "Người ta cho rằng rễ còn tác dụng nhanh hơn bông.",
        "cach_dung_bao_che": "phơi hay sấy khô"
      },
      "confidence_score": 0.95
    }
  ],
