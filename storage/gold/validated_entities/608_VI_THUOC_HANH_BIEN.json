    "id": "VI_THUOC_HANH_BIEN",
    "ten_raw": "Hành biển",
    "ten_khoa_hoc": "$Scilla maritima L.; Urginea scilla Steinh.; Urginea maritima (L.) Baker$",
    "ho_thuc_vat": "$Họ Hành Alliaceae$",
    "variants": [],
    "properties": {
      "bo_phan_dung": "dò",
      "thu_hai": "tại việt nam lá lụi vào mùa hè và xuất hiện vào mùa đông.",
      "che_bien_tho": "không có thông tin",
      "lieu_dung_chung": "Không có thông tin",
      "muc_do_doc": "Không độc",
      "trieu_chung_ngo_doc": "Không có thông tin",
      "phan_bo": "Cây hành biển mọc hoang tại những bãi cát quanh biển những vùng địa Trung Hải nhưng nhiều nhất tại những nước ở bắc châu Phi như Angiêri, đảo Sicile (Ý), đảo Corse (Pháp), có khi mọc rất xa trong đất liền. Trước đây tại Việt Nam không có: Năm 1958 chúng tôi chỉ xin vài củ non từ vùng Xukhumi (miền nam Liên Xô cũ) về trồng ở vườn Trường đại học y dược nay được phổ biến tại một số vườn thuốc khác. Ngay tại Liên Xô cũ trước đây cũng không có: Từ năm 1930 vườn Xukhumi di thực từ nước ngoài về vài củ rồi từ đó phát triển ra. Hành biển mọc hoang ở ven biển Địa Trung Hải, nhất là tại Algérie, Maroc, Tây Ban Nha, đảo Xixin và đảo Sardaigne. Tại Liên Xô cũ, người ta thấy mọc ở ven biển Crưm và ven biển Cápca. Tại Việt Nam, hiện nay chưa thấy."
    },
    "display_name": "Hành biển",
