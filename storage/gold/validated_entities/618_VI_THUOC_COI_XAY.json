  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T618",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "618"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây nhỏ mọc thành bụi, cao chừng $1$-$1,5m$. Toàn thân và các bộ phận của cây đều mang lông măng. Lá mềm, hình tim, đầu nhọn dài rộng chừng $10cm$. Hoa mọc ở kẽ lá, đơn độc, màu vàng, cuống hoa dài bằng cuống lá. Đài $5$ răng không có tiểu đài. Nhị nhiều. Nhuỵ gồm tới $20$ lá noãn. Toàn bộ trông giống cái bánh xe hay cái cối xay. Mỗi lá noãn chứa tới $3$ hạt, nhẵn, màu đen nhạt, hình thận ( Hình $468$).",
        "thanh_phan_hoa_hoc": [
          "Trong lá chứa rất nhiều chất nhầy."
        ],
        "cach_dung_bao_che": "Thường người ta dùng lá, thân, rễ và quả tươi hay khô. Vỏ thân còn cho một thứ sợi trắng bóng, dùng làm dây buộc."
      },
      "confidence_score": 0.95
    }
  ],
