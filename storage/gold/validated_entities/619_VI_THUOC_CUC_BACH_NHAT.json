  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T619",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "619"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cúc bách nhật là một cây mọc hằng năm, thân mọc thẳng đứng, cao chừng $50cm$, thân và lá đều có lông mềm, nhỏ. Thân thổ to, hình trụ, trên có phân nhánh, cành hơi hình vuông. Chỗ đốt hơi phình to, mặt hơi có màu tím hồng. Lá đơn, mọc đối, có cuống ngắn, phiến lá hình trứng ngược, dài $5$ đến $10cm$, rộng $2-5cm$ đầu lá nhọn hay hơi tù, phía cuống thon lại thành cuống. Cụm hoa hình đầu, màu tím nhạt hay hồng sẫm hoặc trắng, đường kính của cụm hoa chừng $1,5-2cm$. Mùa hoa: Hạ và thu. Cụm hoa được dùng làm thuốc Cây thảo, sống $1$ năm, cao $0,30-0,60m$. Thân mọc đứng, phân cành ngay từ gốc, màu hơi đỏ, có lông. Lá mọc đối, hình bầu dục, gốc thuôn, đầu tù, dài $5-10cm$, rộng $2-5cm$, phủ đầy lông trắng nhạt. Cụm hoa hình đầu状, gần hình cầu, đường kính $2-2,5cm$, màu đỏ tía, hồng, da cam hay trắng. Lá bắc khô xác, nhọn. Quả bế, hình trứng.",
        "thanh_phan_hoa_hoc": [
          "Trong cụm hoa cúc bạch nhật người ta chiết được các loại betaxyamin trong đó có $gomphrenin I$, $gomphrenin II$, $gomphrenin III$, $gomphrenin V$ và $gomphrenin VI$. Ngoài ra còn có một ít $amaranthin$ và $izoamaranthin$ (Phytochemistry, 1966, 5, 1037 và 1967, 6, 703):"
        ],
        "cach_dung_bao_che": "Người ta hái hoa, phơi hoặc sấy khô."
      },
      "confidence_score": 0.95
    }
  ],
