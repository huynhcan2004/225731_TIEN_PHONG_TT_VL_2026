  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T626",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "626"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Cay (Tân)"
        ],
        "tinh": "Bình"
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Hành lá một loại cỏ sống lâu năm, có mùi đặc biệt. Lá gồm 5-6 lá, hình trụ rỗng, dài $30-50cm$, đường kính $4-8mm$, phía giữa phình lên đầu thuôn nhọn. Cụm hoa mọc trên một cán mang hoa hình trụ, rỗng, cụm hoa hình xim ngấn thành hình tán giả, nhưng cuống tán giả ngắn đến nỗi cụm hoa trông giống hình cầu. Bao hoa gồm 2 vòng, mỗi vòng gồm 3 cánh, 3 lá đài màu trắng 6 nhị, chỉ nhị phình ở gốc, không có răng, bao phấn hình chữ T, 2 ngăn, dài $1mm$, một nhuỵ, bầu thượng, 3 ngăn, mỗi ngăn có nhiều noãn. Quả nang, hình tròn đường kính chừng $6mm$, hạt hình 3 cạnh, màu đen ( Hình 476, Hm 42,3 ). Hành là một loại cỏ sống lâu năm, có thân hành trắng, hình trụ, phía dưới hơi phình ra. Lá hình trụ rỗng, dài $20-50cm$, phía dưới ôm lấy nhau thành một cái cổ hành giả. Cán hoa hình trụ, rỗng, dài bằng lá hay hơn. Cụm hoa hình cầu mang nhiều hoa nhỏ màu trắng. Quả nang nhỏ chứa nhiều hạt nhỏ màu đen. Toàn cây có mùi đặc biệt.",
        "thanh_phan_hoa_hoc": [
          "Trong hành có axit malic, phytin và chất $alylsunfit$. Có tác giả nói trong hành có tinh dầu, trong tinh dầu chủ yếu có chất kháng sinh $alixin$."
        ],
        "ghi_chu_bo_sung": "Thông là rỗng, bạch là trắng; vì dọc cây hành (lá) thì rỗng, dò hành (“củ”) có màu trắng, do đó có tên này.",
        "cach_dung_bao_che": "Hành được trồng ở khắp nơi trong nước ta để làm gia vị và làm thuốc. Thường dùng tươi."
      },
      "confidence_score": 0.95
    }
  ],
