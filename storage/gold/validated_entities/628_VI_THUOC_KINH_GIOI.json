    {
      "source": {
        "source_id": "CT_VT_VN_T628",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "628"
      },
      "dac_tinh_yhct": {
