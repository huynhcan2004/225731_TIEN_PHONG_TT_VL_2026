  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T652",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "652"
      },
      "dac_tinh_yhct": {
        "vi": [
          "Ngọt (Cam)",
          "Cay (Tân)"
        ],
        "tinh": "Bình",
        "quy_kinh": [
          "K_TY",
          "K_VI"
        ],
        "cong_nang": "giải cơ, thoải nhiệt, sinh tân chỉ khát",
        "kieng_ky_dac_biet": "Không có thông tin"
      },
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Sắn dây là một loại dây leo, có thể dài tới 10m, rễ phát triển to lên thành củ, nhiều bột. Thân cây hơi có lông. Lá kép gồm 3 lá chét; lá chét hình trứng, bản thân lá chét lại chia thành 2-3 thuỳ rõ rệt phiến lá chét dài 7-15cm, rộng 5-12cm có lông nằm rạp trên 2 mặt lá, cuống lá chét giữa dài, cuống 2 lá chét hai bên ngắn hơn. Hoa màu xanh, mọc thành chùm ở kẽ lá. Quả giáp dài 9-10cm, rộng $10mm$, màu vàng nhạt, rất nhiều lông ( Hình 495, Hm 24,3).",
        "thanh_phan_hoa_hoc": [
          "Trong sắn dây, hiện nay người ta mới chỉ thấy có tinh bột với tỷ lệ $12-15\\%$ (tỉnh trên rễ tươi). Mới đây hệ dược của Viện y học Bắc Kinh có tìm thấy trong cát căn có chất $saponozit$.",
          "Trong sắn dây, còn thấy $puerarin$ là một flavonozit:",
          "Trong lá sắn dây có $asparagin$, $adenin$ và $axit amin$.",
          "Trong loài sắn dây Pueraria lobata (Wild) Ohwi có $daidzein$, $daidzein-4’7-diglucozit$.",
          "Theo Murakani T., trong cát căn có $puerarin$, $puerarin-7-xylozit$; người ta còn thấy có 4’6\"-0-diaxetyl-$puerarin$."
        ],
        "cach_dung_bao_che": "Nếu muốn chế bột sắn dây thì giã nhỏ, gạn lấy tinh bột, lọc đi lọc lại nhiều lần, phơi khô."
      },
      "confidence_score": 0.95
    }
  ],
