      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây tô mộc là một cây cao $7-10m$, thân có gai. Lá kép lông chim, gồm $12$ đôi, hay hơn $12$ đôi lá chét, hơi hẹp ở phía dưới tròn ở đầu, mặt trên nhẵn, mặt dưới có lông. Hoa $5$ cánh màu vàng mọc thành chùm, nhị hơi lòi ra, nửa dưới chỉ nhị hơi có lông, bầu hoa phủ lông xám. Quả là một giáp dẹt hình trứng ngược dày, dai, cứng, dài từ $7-10cm$, rộng từ $3,5-4cm$, trong có $3-4$ hạt màu nâu (Hình $19$, Hm $12,1$).",
        "thanh_phan_hoa_hoc": [
          "Trong cây tỏ mộc có tanin, axit galic, chất `$sappanin$`, chất `$brasilin$` và tinh dầu."
        ],
        "cach_dung_bao_che": "Người ta dùng gỗ chẻ mỏng phơi khô."
      },
      "confidence_score": 0.95
    }
  ],
