    "display_name": "Đinh hương",
    "ten_khoa_hoc": "$Syzygium aromaticum (L.) Merr.et Perry; Eugenia caryophyllata Thunb.; Eygenia caryophillus (Sprengel) Bullock et. Hariss$",
    "ho_thuc_vat": "$Sim Myrtaceae (Myrtaceae)$",
    "variants": [],
    "properties": {
      "bo_phan_dung": "hoa",
      "thu_hai": "không có thông tin",
      "che_bien_tho": "không có thông tin",
