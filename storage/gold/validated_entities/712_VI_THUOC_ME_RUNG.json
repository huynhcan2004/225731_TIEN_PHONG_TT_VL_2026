          "tanin",
          "axit corilagin",
          "terchebin",
          "axit chebulic",
          "axit galic",
          "axit ellagic",
          "axit phyllemblic",
          "emblicol",
          "axit muxic",
          "vitamin C",
          "kaempferol 3-glucozit"
        ]
      },
      "confidence_score": 0.95
    }
