  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T723",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "723"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây đào là một cây nhỏ, cao $3-4m$, da thân cây nhẵn. Trên thân thường có chất nhầy đùn ra gọi là nhựa đào. Lá đơn, mọc so le, có cuống ngắn, hình mác. Phiến lá dài $5-8cm$, rộng $1,2-1,5cm$, mép lá có răng cưa. Khi vò có mùi hạnh nhân. Hoa xuất hiện trước lá, màu hồng nhạt, 5 cánh, 8 nhị màu vàng. Quả hạch hình cầu, đầu nhọn có một ngấn lõm vào, chạy dọc theo quả. Vỏ ngoài có lông rất mịn. Quả chín có những đám đỏ ( Hình 544, Hm 20,4 ).",
        "thanh_phan_hoa_hoc": [],
        "lieu_dung_tong_quat": "Không tìm thấy",
        "ghi_chu_bo_sung": "Không tìm thấy",
        "cach_dung_bao_che": "Không tìm thấy"
      },
      "confidence_score": 0.95
    }
