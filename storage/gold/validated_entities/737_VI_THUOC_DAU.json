    "ten_raw": "Cây dâu",
    "ten_khoa_hoc": "$Morus alba L.; Morus acidosa Griff.$",
    "ho_thuc_vat": "$Dâu tằm Moraceae$",
    "variants": [],
    "properties": {
      "bo_phan_dung": "lá, cành, vỏ rễ, quả, tổ bọ ngựa",
      "thu_hai": "không có thông tin",
      "che_bien_tho": "không có thông tin",
      "lieu_dung_chung": "Tang diệp chữa sốt, cho ra mồ hồi, cảm mạo, trừ đờm, cao huyết áp, làm cho sáng mắt. Liều dùng $6$-$18g$ dưới dạng thuốc sắc. Tang thầm bổ thận, sáng mắt, bổ toàn thân, giúp sự tiêu hoá, chữa bệnh kém ngủ, râu tóc sớm bạc. Liều dùng $12$-$20g$. Tang bạch bì làm thuốc lợi tiểu tiện, dùng trong bệnh thuỷ thùng, chữa ho lâu ngày, hen, họ có đờm, băng huyết, chữa sốt, chữa cao huyết áp. Liều dùng hằng ngày $6$-$18g$ dưới dạng thuốc sắc hay thuốc bột. Tang ký sinh bổ gan thận, chữa đau lưng, đau mình, an thai, đẻ xong ít sữa. Liều dùng $12$-$20g$ dưới dạng thuốc sắc. Tang phiền tiêu lợi tiểu tiện. Chữa đi đái nhiều lần, di tinh, liệt dương, bạch đới, trẻ con đái dầm. Liều dùng $6$-$12g$.",
      "muc_do_doc": "Không độc",
      "trieu_chung_ngo_doc": "Không có thông tin",
      "phan_bo": "Trung Quốc, Việt Nam"
    },
