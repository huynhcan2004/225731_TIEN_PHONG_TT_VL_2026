  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T778",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "778"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Ruột gà là một loại cỏ sống dai, thân nhẵn mọc bò, mang rễ, dài $10-40cm$, mang những cành mềm mọc đứng. Lá mọc đối không cuống, thuôn, tù, dài $8-12mm$, rộng $3-5mm$. Hoa mọc riêng lẻ màu trắng. Quả nang hình trứng, nhẵn, có đài còn lại, hạt nhỏ, có góc cạnh. Mùa hoa tháng 4-6",
        "thanh_phan_hoa_hoc": [
          "Từ ruột gà, năm 1931, Bose chiết được ancaloit dạng tinh thể ($brahmin$). Năm 1947, Basu chiết được $herpestin$."
        ],
        "ghi_chu_bo_sung": "Qua những tài liệu cũ (A. Pételot- Cây thuốc ở Cămpuchia, Lào, Việt Nam, 1953) thì cây này được khai thác ở những tỉnh Phú Thọ, Hoà Bình, Lào Cai với tên ba kích để xuất sang Trung Quốc. Nhưng qua điều tra của chúng tôi thì cây này không thấy được khai thác lớn, mà chỉ được dùng trong phạm vi địa phương theo kinh nghiệm của một số ít người."
      },
      "confidence_score": 0.95
    }
  ],
