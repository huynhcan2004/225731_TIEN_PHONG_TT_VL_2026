    "properties": {
      "bo_phan_dung": "lá",
      "lieu_dung_chung": "Nếu dùng khô ngày dùng $20-40$g, nếu dùng tươi ngày dùng $40-80$g dưới dạng thuốc sắc. Uống hàng ngày cho tới khi bệnh hết.",
      "muc_do_doc": "Không độc",
      "phan_bo": "Nắp ấm là một cây chủ yếu mọc hoang dại ở các tỉnh miền Trung và Nam bộ. Còn thấy ở chân núi đá vôi các tỉnh nói trên. Tại miền Bắc chỉ mới gặp ở Vĩnh Linh.",
      "thu_hai": "mùa hoa thường gặp vào tháng giêng. người ta thu hái toàn cây, quanh năm",
      "che_bien_tho": "rửa sạch, chặt thành từng đoạn $2$-$3cm$, phơi nắng cho khô dùng dân."
    },
