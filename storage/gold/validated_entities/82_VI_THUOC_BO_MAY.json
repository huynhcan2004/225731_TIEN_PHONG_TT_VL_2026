      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây nhỏ, cành tròn, lúc non có lông sau nhẵn. Lá hình mác đầu nhọn, phía cuống cũng nhọn, hay hơi tròn, hai mặt đều nhẵn, màu xanh lục sẫm, dài $5$-$13cm$, rộng $3$-$7cm$, gần nổi rõ ở mặt dưới. Cụm hoa hình ngù chùy, nhẵn, mang những nhánh hoa thưa, màu trắng, đôi khi màu hồng. Đài và tràng hoa có lông. Nhị thòi dài gấp $2ống$ hoa. Nhụy có vòi dài bằng hay gần bằng nhị, núm xẻ hai. Quả nhỏ bọc trong đài",
        "thanh_phan_hoa_hoc": [
          "Sơ bộ chúng tôi thấy có $ancaloit$."
        ],
        "lieu_dung_tong_quat": "Thường hái toàn cây, bỏ rễ đem về phơi hay sấy khô mà dùng. Không phải chế biến gì, hoặc chỉ sao vàng cho thơm.",
        "cach_dung_bao_che": "Không phải chế biến gì, hoặc chỉ sao vàng cho thơm."
      },
