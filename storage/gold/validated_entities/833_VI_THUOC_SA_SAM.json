    "id": "VI_THUOC_SA_SAM",
    "ten_raw": "Sa sâm",
    "ten_khoa_hoc": "$Launaea pinnatifida Cass (Microrhynchus sarmentosus DC., Prenanthes sarmentosa Willd.); Adenophora verticillata Fisch (Adenophora tetraphylla (Thunb) Fisch.); Wahlenbergia gracilis A.DC. hay Campanula vincaeflora Vent; Glehnia littoralis F. Schmidt (Phellopteris littoralis Benth)$",
    "ho_thuc_vat": "$Cúc Asteraceae (Compositae); Hoa chuông Campanulaceae; Hoa tán Umbelliferae$",
    "variants": [
      "Radix Glehniae"
    ],
    "properties": {
      "bo_phan_dung": "rễ",
      "thu_hai": "phơi hay sấy khô",
      "lieu_dung_chung": "[CT_VT_VN_T834]: Liều dùng $6-12g$ một ngày dưới dạng thuốc sắc, phối hợp với các vị thuốc khác. [CT_VT_VN_T834]: Liều dùng $6-12g$ dưới dạng thuốc sắc. [CT_VT_VN_T835]: Liều dùng $8-16g$ dưới dạng thuốc sắc. Thường uống phối hợp với các vị thuốc khác.",
      "muc_do_doc": "Không độc",
      "phan_bo": "Các bờ biển Việt Nam, vùng Quảng Ninh, Nam Định, Hà Nam, . Nghệ An, Hà Tĩnh, Quảng Bình; Trung Quốc tại các tỉnh Hắc Long Giang, Cát Lâm, Liêu Ninh, Hà Bắc, Sơn Đông, Hà Nam, An Huy, Giang Tô, Triết Giang, Quảng Đông, Giang Tây; Lào và Cămpuchia.",
      "che_bien_tho": "rửa sạch bằng nước vo gạo, đồ chín rồi phơi khô, hoặc hái về rửa sạch, ngâm nước phèn chua $1/5$ hoặc $2/5$, phơi cho se, xông diêm sinh hơn $1$ giờ rồi mới phơi khô hẳn.",
      "trieu_chung_ngo_doc": "Không tìm thấy"
    },
