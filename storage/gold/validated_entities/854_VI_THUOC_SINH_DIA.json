    {
      "from": "VI_THUOC_SINH_DIA",
      "to": "DL_HA_DUONG_HUYET",
      "relation_type": "CO_TAC_DUNG_DUOC_LY",
      "properties": {
        "mo_ta_chi_tiet": "Catalpol có tác dụng hạ thấp đường huyết trên súc vật thí nghiệm. Sắc nước sinh địa cho thỏ uống không có hiện tượng gì. Trong cồn ngâm sinh địa có chứa chất $rehmanin$ có lẽ đó là thành phần gây hạ huyết đường. Tiêm dưới da cho thỏ chất $rehmanin$ với liều $0,$5g$/1kg$ thể trọng thì thấy sau 30 phút lượng huyết đường giảm xuống, 4 giờ sau lượng huyết hạ thấp nhất, rồi dần dần trở lại bình thường, 7 giờ sau khi tiêm, lượng huyết trở lại mức bình thường. Tiêm thuốc dưới da làm cho lượng huyết đường giảm xuống; 4 giờ sau khi tiêm, lượng đường xuống rõ nhất, sau đó trở lại bình thường, uống sinh địa cũng làm lượng đường giảm xuống nhưng không bằng tiêm. Sinh địa có khả năng ức chế khả năng của các hợp chất cacbon hydrat, làm kéo dài sự tăng lượng huyết đường. $10ml$ cao sinh địa tiêm vào bắp thịt thỏ có thể hạ 2/3 huyết đường do adrenalin gây ra, tiêm cao sinh địa trước khi tiêm adrenalin thì có thể đề phòng hiện tượng huyết đường quá cao. Tiêm $20ml$ cao sinh địa vào bắp thịt một con chó nặng $4,5kg$ có thể hạ thấp lượng huyết đường do tiêm $20ml$ dung dịch $25\\%$ glucoza đưa đến huyết đường quá cao, nếu cho uống cũng có kết quả. Hoạt chất gây hạ huyết đường trong sinh địa là một chất tan trong nước, trung tính màu vàng nhạt giống như dầu, có thể có chứa sunfua và nitơ.",
        "ghi_chu": "Ức chế huyết đường tăng cao do adrenalin."
      },
      "source": {
        "source_id": "CT_VT_VN_T854",
        "all_sources": [
          "CT_VT_VN_T854"
        ]
      },
      "confidence_score": 0.75
    },
    {
      "from": "VI_THUOC_SINH_DIA",
