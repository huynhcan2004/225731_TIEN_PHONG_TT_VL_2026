  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T869",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "869"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây tơ hồng hay dây tơ hồng là một loại dây ký sinh cuốn trên các cây khác, thân thành sợi màu vàng hay đỏ nâu nhạt, không có lá. Lá biến thành vẩy, cây có rễ mút để hút các thức ăn từ cây chủ. Hoa ít thấy, hình cầu màu trắng nhạt, gần như không có cuống, tụ thành 10-20 hoa một. Quả hình cầu, chiều ngang rộng hơn chiều cao, rộng độ $3mm$, nứt từ dưới lên. Hạt 2 đến 4, hình trứng, đỉnh dẹt, dài chứng $2mm$ (Hình 651). Tại miền Bắc hay gặp nó ký sinh trên cây cúc tần Pluchea indica thuộc họ Cúc Asteraceae (Compositae).",
        "thanh_phan_hoa_hoc": [
          "Trong hạt thỏ ty tử người ta mới thấy có một chất nhựa, tính chất glucozit gọi là $cuscutin$. Hoạt chất khác chưa rõ."
        ],
        "lieu_dung_tong_quat": "Không đề cập",
        "ghi_chu_bo_sung": "Không đề cập",
        "cach_dung_bao_che": "Không đề cập"
      },
      "confidence_score": 0.95
    }
  ],
