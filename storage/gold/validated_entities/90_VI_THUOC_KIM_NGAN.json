  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T90",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "90"
      },
      "dac_tinh_yhct": {
        "vi": [
