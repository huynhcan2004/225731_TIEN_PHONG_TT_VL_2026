  "claims": [
    {
      "source": {
        "source_id": "CT_VT_VN_T911",
        "ten_sach": "Những cây thuốc và vị thuốc Việt Nam",
        "tac_gia": "Đỗ Tất Lợi",
        "trang": "911"
      },
      "dac_tinh_yhct": {},
      "mo_ta_theo_nguon": {
        "hinh_thai_chi_tiet": "Cây mọc bụi, lá kép lông chim, nhiều gai. Hoa nhỏ bé, đẹp nhiều màu khác nhau đỏ, trắng, vàng v.v.. 5 cánh hoa Tầm xuân là một loại cây leo bằng thân nhờ có gai quặp. Cành non màu xanh lục nhạt, có lông và gai. Cành già màu nâu nhạt. Lá kép lông chim lẻ, thường gồm 5-9 lá chét hình trứng, dài $2$-$5cm$, rộng $1$-$3cm$, mép có răng cưa nhỏ, mặt trên nhẵn, mặt dưới có lông, vò ra có mùi thơm nhẹ. Lá kèm hình sợi. Hoa nhỏ màu trắng, mọc thành chùy ở ngọn cành. Đài có 5 răng, tràng có 5 cánh. Nhị nhiều. Quả bế đựng trong đế hoa hình trứng, khi chín có màu đỏ tươi. Mùa hoa: tháng 5-7, mùa quả: tháng 8-10.",
        "thanh_phan_hoa_hoc": [
          "Trong tầm xuân có $tinh dầu$, $tanin$, $chất màu$."
        ]
      },
      "confidence_score": 0.95
    }
  ],
